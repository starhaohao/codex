{%- liquid
  assign bg_type = section.settings.bg_type
  assign hero_height = section.settings.hero_height
  assign overlay_from = section.settings.overlay_from
  assign overlay_to = section.settings.overlay_to
  assign eyebrow_color = section.settings.eyebrow_color
  assign title_size = section.settings.title_size
  assign show_countdown = section.settings.show_countdown
  assign countdown_end = section.settings.countdown_end
-%}

<section class="lh" style="--lh-h:{{ hero_height }}vh;--lh-ov1:{{ overlay_from }};--lh-ov2:{{ overlay_to }};--lh-eye:{{ eyebrow_color }};--lh-ts:{{ title_size }}px;">

  {%- if bg_type == 'video' and section.settings.video_url != blank -%}
    <video class="lh__bg" autoplay muted loop playsinline>
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {%- elsif section.settings.image != blank -%}
    <img class="lh__bg" src="{{ section.settings.image | image_url: width: 2800 }}" alt="{{ section.settings.image.alt | escape }}" loading="eager">
  {%- else -%}
    <div class="lh__bg lh__bg--placeholder"></div>
  {%- endif -%}

  <div class="lh__overlay"></div>

  {%- if section.settings.show_urgency -%}
    <div class="lh__urgency">
      <div class="lh__urgency-label">{{ section.settings.urgency_label }}</div>
      <div class="lh__urgency-tag">{{ section.settings.urgency_text }}</div>
    </div>
  {%- endif -%}

  <div class="lh__content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="lh__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    <h1 class="lh__title">{{ section.settings.title }}</h1>

    {%- if section.settings.subtitle != blank -%}
      <div class="lh__sub">{{ section.settings.subtitle }}</div>
    {%- endif -%}

    {%- if show_countdown and countdown_end != blank -%}
      <div class="lh__countdown" data-end="{{ countdown_end }}">
        <div class="lh__cd-block"><span class="lh__cd-num" data-days>00</span><span class="lh__cd-lbl">Days</span></div>
        <div class="lh__cd-sep">:</div>
        <div class="lh__cd-block"><span class="lh__cd-num" data-hours>00</span><span class="lh__cd-lbl">Hrs</span></div>
        <div class="lh__cd-sep">:</div>
        <div class="lh__cd-block"><span class="lh__cd-num" data-mins>00</span><span class="lh__cd-lbl">Min</span></div>
        <div class="lh__cd-sep">:</div>
        <div class="lh__cd-block"><span class="lh__cd-num" data-secs>00</span><span class="lh__cd-lbl">Sec</span></div>
      </div>
    {%- endif -%}

    <div class="lh__ctas">
      {%- if section.settings.cta_text != blank -%}
        <a class="lh__cta" href="{{ section.settings.cta_url }}" style="background:{{ section.settings.cta_bg }};color:{{ section.settings.cta_text_color }};">{{ section.settings.cta_text }} →</a>
      {%- endif -%}
      {%- for block in section.blocks -%}
        <a class="lh__cta-ghost" href="{{ block.settings.url }}">{{ block.settings.label }}</a>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- if show_countdown and countdown_end != blank -%}
<script>
(function() {
  var el = document.querySelector('.lh__countdown[data-end]');
  if (!el) return;
  var end = new Date(el.dataset.end).getTime();
  function pad(n) { return String(n).padStart(2, '0'); }
  function tick() {
    var diff = end - Date.now();
    if (diff <= 0) { el.innerHTML = '<span style="font-size:12px;letter-spacing:0.1em;color:rgba(255,255,255,0.5)">SALE ENDED</span>'; return; }
    el.querySelector('[data-days]').textContent = pad(Math.floor(diff / 86400000));
    el.querySelector('[data-hours]').textContent = pad(Math.floor((diff % 86400000) / 3600000));
    el.querySelector('[data-mins]').textContent = pad(Math.floor((diff % 3600000) / 60000));
    el.querySelector('[data-secs]').textContent = pad(Math.floor((diff % 60000) / 1000));
  }
  tick();
  setInterval(tick, 1000);
})();
</script>
{%- endif -%}

<script src="{{ 'triiiple-animations.js' | asset_url }}" defer></script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400&display=swap');

  /* ── Hero keyframe animations (above-fold, play immediately) ── */
  @keyframes lhBgReveal {
    from { transform: scale(1.04); opacity: 0.6; }
    to   { transform: scale(1);    opacity: 1; }
  }
  @keyframes lhFadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .lh {
    overflow-x: hidden;
    box-sizing: border-box;
    max-width: 100%;
    position: relative;
    height: var(--lh-h);
    min-height: 500px;
    overflow: hidden;
  }
  .lh__bg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
    animation: lhBgReveal 1.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .lh__bg--placeholder { background: #1a1d20; }
  .lh__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to right, var(--lh-ov1) 0%, var(--lh-ov2) 52%, rgba(10,10,10,0.04) 100%);
  }
  .lh__urgency {
    position: absolute;
    top: 40px; right: 48px;
    text-align: right;
    z-index: 2;
  }
  .lh__urgency-label {
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 6px;
  }
  .lh__urgency-tag {
    font-size: 13px;
    letter-spacing: -0.02em;
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
  }
  .lh__content {
    position: absolute;
    bottom: 72px; left: 64px;
    max-width: 560px;
    z-index: 2;
  }
  .lh__eyebrow {
    font-family: 'IBM Plex Sans', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--lh-eye);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    animation: lhFadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  .lh__eyebrow::before {
    content: '';
    display: block;
    width: 24px; height: 1px;
    background: var(--lh-eye);
  }
  .lh__title {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: clamp(36px, 5.8vw, var(--lh-ts));
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 0.96;
    color: #fff;
    margin-bottom: 24px;
    animation: lhFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.28s both;
  }
  .lh__sub {
    font-family: 'IBM Plex Sans', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin-bottom: 28px;
    line-height: 2.2;
    animation: lhFadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.44s both;
  }
  .lh__countdown {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 28px;
  }
  .lh__cd-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 52px;
  }
  .lh__cd-num {
    font-size: 28px;
    font-weight: 300;
    letter-spacing: -0.04em;
    color: #fff;
    line-height: 1;
  }
  .lh__cd-lbl {
    font-family: monospace;
    font-size: 7px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-top: 4px;
  }
  .lh__cd-sep {
    font-size: 20px;
    color: rgba(255,255,255,0.35);
    padding-bottom: 14px;
    line-height: 1;
  }
  .lh__ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
    animation: lhFadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.58s both;
  }
  .lh__cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 28px;
    font-family: 'IBM Plex Sans', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  .lh__cta:hover { opacity: 0.88; transform: translateY(-1px); }
  .lh__cta-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: rgba(255,255,255,0.8);
    border: 1px solid rgba(255,255,255,0.28);
    padding: 13px 22px;
    font-family: 'IBM Plex Sans', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color 0.22s ease, color 0.22s ease, transform 0.22s ease;
  }
  .lh__cta-ghost:hover { border-color: rgba(255,255,255,0.7); color: #fff; transform: translateY(-1px); }
  @media (max-width: 749px) {
    .lh { height: 100svh; min-height: 560px; }
    .lh__content { bottom: 40px; left: 24px; right: 24px; }
    .lh__urgency { top: 20px; right: 20px; }
    .lh__cd-num { font-size: 22px; }
    .lh__cd-block { min-width: 42px; }
  }
</style>

{% schema %}
{
  "name": "Landing Hero + Countdown",
  "tag": "div",
  "class": "landing-hero-section",
  "settings": [
    { "type": "header", "content": "Background" },
    {
      "type": "select",
      "id": "bg_type",
      "label": "Background type",
      "default": "image",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video (MP4 URL)" }
      ]
    },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "video_url", "label": "Video URL (.mp4)", "info": "Direct .mp4 URL for autoplay background video" },
    { "type": "range", "id": "hero_height", "label": "Height (vh)", "min": 50, "max": 100, "step": 2, "default": 92 },
    { "type": "color", "id": "overlay_from", "label": "Overlay start", "default": "rgba(10,10,10,0.75)" },
    { "type": "color", "id": "overlay_to", "label": "Overlay end", "default": "rgba(10,10,10,0.32)" },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New Season" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#923531" },
    { "type": "richtext", "id": "title", "label": "Title", "default": "<p>Wear Less.<br>Feel More.</p>" },
    { "type": "range", "id": "title_size", "label": "Title max size (px)", "min": 36, "max": 120, "step": 2, "default": 84 },
    { "type": "richtext", "id": "subtitle", "label": "Subtitle", "default": "<p>Premium basics for the modern man</p>" },
    { "type": "header", "content": "Urgency tag (top right)" },
    { "type": "checkbox", "id": "show_urgency", "label": "Show urgency tag", "default": false },
    { "type": "text", "id": "urgency_label", "label": "Label", "default": "Drops In" },
    { "type": "richtext", "id": "urgency_text", "label": "Text", "default": "<p>New drop.<br>Limited stock.</p>" },
    { "type": "header", "content": "Countdown Timer" },
    { "type": "checkbox", "id": "show_countdown", "label": "Show countdown", "default": false },
    { "type": "text", "id": "countdown_end", "label": "End date/time", "info": "Format: 2025-12-31T23:59:59", "default": "2025-12-31T23:59:59" },
    { "type": "header", "content": "Primary CTA" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Shop Now" },
    { "type": "url", "id": "cta_url", "label": "Button link" },
    { "type": "color", "id": "cta_bg", "label": "Button background", "default": "#923531" },
    { "type": "color", "id": "cta_text_color", "label": "Button text color", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "ghost_cta",
      "name": "Ghost CTA",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Shop Briefs" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing Hero (+ Countdown)",
      "blocks": [
        { "type": "ghost_cta", "settings": { "label": "Briefs" } },
        { "type": "ghost_cta", "settings": { "label": "Boxer Trunks" } }
      ]
    }
  ],
  "templates": ["index", "page"]
}
{% endschema %}
