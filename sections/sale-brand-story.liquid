{%- liquid
  assign bg = section.settings.bg_color
  assign border = section.settings.border_color
  assign eyebrow_color = section.settings.eyebrow_color
  assign title_color = section.settings.title_color
  assign body_color = section.settings.body_color
-%}

<section class="sbs" style="--sbs-bg:{{ bg }};--sbs-bd:{{ border }};--sbs-ec:{{ eyebrow_color }};--sbs-tc:{{ title_color }};--sbs-bc:{{ body_color }};">
  <div class="sbs__text">
    <div class="sbs__eyebrow">{{ section.settings.eyebrow }}</div>
    <h2 class="sbs__title">{{ section.settings.title }}</h2>
    <p class="sbs__body">{{ section.settings.body }}</p>
  </div>
  <div class="sbs__img">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy">
    {%- endif -%}
  </div>
</section>

<style>
  .sbs {
    overflow-x: hidden;
    box-sizing: border-box;
    max-width: 100%;
    background: var(--sbs-bg);
    border-top: 1px solid var(--sbs-bd);
    padding: 72px 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .sbs__eyebrow {
    font-family: monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--sbs-ec);
    margin-bottom: 16px;
  }
  .sbs__title {
    font-size: 36px;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--sbs-tc);
    margin-bottom: 20px;
    font-weight: 400;
  }
  .sbs__body {
    font-size: 13px;
    line-height: 1.75;
    color: var(--sbs-bc);
    max-width: 380px;
  }
  .sbs__img {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .sbs__img img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.8);
    display: block;
  }
  @media (max-width: 749px) {
    .sbs { grid-template-columns: 1fr; gap: 32px; padding: 48px 16px; }
    .sbs__title { font-size: 28px; }
  }
</style>

{% schema %}
{
  "name": "Sale Brand Story",
  "tag": "div",
  "class": "sale-brand-story-section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#212529" },
    { "type": "color", "id": "border_color", "label": "Border", "default": "rgba(255,255,255,0.11)" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "rgba(255,255,255,0.42)" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "color", "id": "body_color", "label": "Body color", "default": "rgba(255,255,255,0.42)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Studio" },
    { "type": "richtext", "id": "title", "label": "Title", "default": "<p>Designed in Singapore.<br>Crafted in Thailand.</p>" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>TRIIIPLE was built on a single premise — that underwear should be engineered, not just made. Every cut, every stitch, every fabric blend is a deliberate decision. This is not basics. This is the baseline.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" }
  ],
  "presets": [
    {
      "name": "Sale Brand Story"
    }
  ],
  "templates": ["page","index"]
}
{% endschema %}
