{% comment %}
  Story Salon — Blog Index Section
  Template: templates/blog.storysalon.json
  Blog handle: storysalon
  Version: 1.0
{% endcomment %}

{%- assign blog_obj = blogs['storysalon'] -%}

<style>
  /* ─── RESET & BASE ─── */
  *, *::before, *::after { box-sizing: border-box; }

  :root {
    --ss-black:     #0a0a0a;
    --ss-white:     #ffffff;
    --ss-off-white: #f4f3f1;
    --ss-neon:      #c8ff00;
    --ss-grey-100:  #f0efed;
    --ss-grey-200:  #e0dedd;
    --ss-grey-400:  #a0a0a0;
    --ss-grey-700:  #4a4a4a;
    --ss-pill:      999px;
    --ss-ease:      0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* ─── HERO ─── */
  .ss-hero {
    background: var(--ss-black);
    color: var(--ss-white);
    padding: 72px 48px 60px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .ss-hero__title {
    font-size: clamp(38px, 5vw, 58px);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.03em;
    margin: 0;
  }
  .ss-hero__title span { color: var(--ss-neon); }
  .ss-hero__tagline {
    font-size: 13px;
    line-height: 1.65;
    color: var(--ss-grey-400);
    max-width: 420px;
    margin: 0;
  }
  .ss-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    margin-top: 6px;
    padding: 12px 24px;
    border-radius: var(--ss-pill);
    background: var(--ss-neon);
    color: var(--ss-black);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity var(--ss-ease);
  }
  .ss-hero__cta:hover { opacity: 0.82; color: var(--ss-black); }
  .ss-hero__cta svg { width: 13px; height: 13px; flex-shrink: 0; }

  /* ─── TOPIC PILLS ─── */
  .ss-topics {
    padding: 18px 48px;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--ss-off-white);
    border-bottom: 1px solid var(--ss-grey-200);
    flex-wrap: wrap;
  }
  .ss-topic-pill {
    display: inline-flex;
    align-items: center;
    height: 32px;
    padding: 0 16px;
    border-radius: var(--ss-pill);
    border: 1.5px solid var(--ss-grey-200);
    background: transparent;
    font-size: 11px;
    letter-spacing: 0.04em;
    cursor: pointer;
    font-family: inherit;
    color: var(--ss-grey-700);
    transition: all var(--ss-ease);
  }
  .ss-topic-pill.is-active {
    background: var(--ss-black);
    border-color: var(--ss-black);
    color: var(--ss-white);
  }
  .ss-topic-pill:hover:not(.is-active) {
    border-color: var(--ss-black);
    color: var(--ss-black);
  }
  .ss-topic-pill .hash {
    color: var(--ss-neon);
    font-weight: 700;
    margin-right: 1px;
  }
  .ss-topic-pill.is-active .hash { color: var(--ss-neon); }

  /* ─── GRID ─── */
  .ss-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--ss-grey-200);
    padding: 2px;
  }

  /* ─── ARTICLE CARD ─── */
  .ss-card {
    position: relative;
    overflow: hidden;
    background: var(--ss-black);
    aspect-ratio: 3 / 4;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    text-decoration: none;
    color: inherit;
    transition: none;
  }
  .ss-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .ss-card:hover .ss-card__img { transform: scale(1.04); }
  .ss-card__overlay {
    position: relative;
    z-index: 2;
    padding: 24px 24px 28px;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.82) 0%,
      rgba(0, 0, 0, 0.3) 40%,
      transparent 70%
    );
  }
  .ss-card__cat {
    display: block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--ss-neon);
    margin-bottom: 10px;
  }
  .ss-card__title {
    font-size: clamp(17px, 1.8vw, 23px);
    font-weight: 400;
    line-height: 1.15;
    color: var(--ss-white);
    letter-spacing: -0.02em;
    margin: 0 0 10px;
  }
  .ss-card__excerpt {
    font-size: 12px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 18px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ss-card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ss-white);
    border-bottom: 1px solid rgba(255, 255, 255, 0.35);
    padding-bottom: 2px;
    text-decoration: none;
    transition: color var(--ss-ease), border-color var(--ss-ease);
  }
  .ss-card:hover .ss-card__link {
    color: var(--ss-neon);
    border-color: var(--ss-neon);
  }
  .ss-card__link svg { width: 13px; height: 13px; }

  /* hidden state for filter */
  .ss-card[data-hidden="true"] { display: none; }

  /* empty state */
  .ss-empty {
    grid-column: 1 / -1;
    padding: 80px 48px;
    text-align: center;
    font-size: 13px;
    color: var(--ss-grey-400);
    letter-spacing: 0.08em;
    background: var(--ss-off-white);
    display: none;
  }
  .ss-empty.is-visible { display: block; }

  /* ─── PRODUCT STRIP ─── */
  .ss-products {
    background: var(--ss-white);
    padding: 52px 48px 60px;
    border-top: 1px solid var(--ss-grey-200);
  }
  .ss-products__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 28px;
  }
  .ss-products__title {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .ss-products__link {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ss-grey-700);
    border-bottom: 1px solid var(--ss-grey-400);
    padding-bottom: 1px;
    text-decoration: none;
    transition: color var(--ss-ease), border-color var(--ss-ease);
  }
  .ss-products__link:hover { color: var(--ss-black); border-color: var(--ss-black); }
  .ss-products__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--ss-grey-200);
  }
  .ss-product-card {
    background: var(--ss-off-white);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .ss-product-card__img-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--ss-grey-200);
  }
  .ss-product-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .ss-product-card:hover .ss-product-card__img-wrap img { transform: scale(1.04); }
  .ss-product-card__info { padding: 14px 18px 6px; }
  .ss-product-card__name { font-size: 13px; font-weight: 500; margin: 0 0 3px; }
  .ss-product-card__price { font-size: 12px; color: var(--ss-grey-400); margin: 0; }
  .ss-product-card__cta {
    display: block;
    text-align: center;
    margin: 10px 18px 16px;
    padding: 10px;
    border: 1.5px solid var(--ss-black);
    border-radius: var(--ss-pill);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    text-decoration: none;
    color: var(--ss-black);
    transition: background var(--ss-ease), color var(--ss-ease);
  }
  .ss-product-card:hover .ss-product-card__cta,
  .ss-product-card__cta:hover {
    background: var(--ss-black);
    color: var(--ss-white);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .ss-hero { padding: 52px 24px 44px; }
    .ss-topics { padding: 14px 24px; flex-wrap: nowrap; overflow-x: auto; }
    .ss-topics::-webkit-scrollbar { display: none; }
    .ss-grid { grid-template-columns: 1fr; padding: 0; gap: 1px; }
    .ss-card { aspect-ratio: 3 / 4; }
    .ss-card__title { font-size: clamp(22px, 6vw, 28px); }
    .ss-products { padding: 36px 24px 48px; }
    .ss-products__grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .ss-hero__title { font-size: 36px; }
    .ss-card__overlay { padding: 20px 20px 24px; }
  }
</style>

{%- comment %} ─── HERO ─── {%- endcomment %}
<section class="ss-hero" aria-label="Story Salon">
  <h1 class="ss-hero__title">
    Story<br/>
    <span>Salon.</span>
  </h1>
  <p class="ss-hero__tagline">
    {{ section.settings.tagline | default: 'Inspiration, insights, and the art of being. More stories are on their way — pull up a chair.' }}
  </p>
  <a href="{{ section.settings.cta_url | default: '#' }}" class="ss-hero__cta">
    {{ section.settings.cta_label | default: 'More stories coming' }}
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M3 8h10M9 4l4 4-4 4"/>
    </svg>
  </a>
</section>

{%- comment %} ─── COLLECT ALL TAGS ACROSS ARTICLES ─── {%- endcomment %}
{%- assign all_tags = '' -%}
{%- for article in blog_obj.articles limit: 50 -%}
  {%- for tag in article.tags -%}
    {%- unless all_tags contains tag -%}
      {%- if all_tags != '' -%}{%- assign all_tags = all_tags | append: ',' -%}{%- endif -%}
      {%- assign all_tags = all_tags | append: tag -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endfor -%}
{%- assign tag_array = all_tags | split: ',' -%}

{%- comment %} ─── TOPIC PILLS ─── {%- endcomment %}
<div class="ss-topics" id="ss-topics" role="navigation" aria-label="Filter stories by topic">
  <button class="ss-topic-pill is-active" data-tag="all">All</button>
  {%- for tag in tag_array -%}
    {%- assign tag_slug = tag | handle -%}
    {%- assign tag_display = tag | replace: '-', ' ' | capitalize -%}
    <button class="ss-topic-pill" data-tag="{{ tag_slug }}">
      <span class="hash">#</span>{{ tag_display }}
    </button>
  {%- endfor -%}
</div>

{%- comment %} ─── ARTICLE GRID ─── {%- endcomment %}
<div class="ss-grid" id="ss-grid" role="list">
  {%- paginate blog_obj.articles by 50 -%}
    {%- for article in blog_obj.articles -%}
      {%- assign article_tags = '' -%}
      {%- for tag in article.tags -%}
        {%- assign article_tags = article_tags | append: tag | handle | append: ' ' -%}
      {%- endfor -%}
      {%- assign article_tags = article_tags | strip -%}

      {%- assign first_tag_display = article.tags | first | replace: '-', ' ' | capitalize -%}

      <article
        class="ss-card"
        data-tags="{{ article_tags }}"
        role="listitem"
        itemscope
        itemtype="https://schema.org/BlogPosting"
      >
        {%- if article.image -%}
          <img
            class="ss-card__img"
            src="{{ article.image | image_url: width: 800 }}"
            srcset="
              {{ article.image | image_url: width: 600 }} 600w,
              {{ article.image | image_url: width: 800 }} 800w,
              {{ article.image | image_url: width: 1200 }} 1200w
            "
            sizes="(max-width: 900px) 100vw, 33vw"
            alt="{{ article.image.alt | default: article.title | escape }}"
            loading="lazy"
            itemprop="image"
          />
        {%- else -%}
          <div class="ss-card__img" style="background: linear-gradient(145deg, #1e2228 0%, #0c0e12 100%);"></div>
        {%- endif -%}

        <div class="ss-card__overlay">
          {%- if first_tag_display != blank -%}
            <span class="ss-card__cat" itemprop="keywords">
              <span aria-hidden="true">#</span>{{ first_tag_display | replace: ' ', '' }}
            </span>
          {%- endif -%}
          <h2 class="ss-card__title" itemprop="headline">{{ article.title | escape }}</h2>
          {%- if article.excerpt != blank -%}
            <p class="ss-card__excerpt" itemprop="description">{{ article.excerpt | strip_html | truncate: 120 }}</p>
          {%- endif -%}
          <a href="{{ article.url }}" class="ss-card__link" itemprop="url" aria-label="Read {{ article.title | escape }}">
            Read story
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4"/>
            </svg>
          </a>
        </div>

        {%- comment %} SEO: hidden full link covering the card {%- endcomment %}
        <a href="{{ article.url }}" aria-hidden="true" tabindex="-1" style="position:absolute;inset:0;z-index:1;"></a>
      </article>
    {%- endfor -%}

    <div class="ss-empty" id="ss-empty" role="status" aria-live="polite">
      No stories in this category yet — check back soon.
    </div>
  {%- endpaginate -%}
</div>

{%- comment %} ─── PRODUCT STRIP ─── {%- endcomment %}
{%- if section.settings.show_products -%}
  <section class="ss-products" aria-label="Featured products">
    <div class="ss-products__header">
      <h2 class="ss-products__title">Worn in the stories</h2>
      <a href="{{ section.settings.shop_all_url | default: '/collections/underwear' }}" class="ss-products__link">
        Shop all →
      </a>
    </div>
    <div class="ss-products__grid">
      {%- for i in (1..3) -%}
        {%- assign product_setting = 'product_' | append: i -%}
        {%- assign product = section.settings[product_setting] -%}
        {%- if product != blank -%}
          <a href="{{ product.url }}" class="ss-product-card" aria-label="{{ product.title | escape }}">
            <div class="ss-product-card__img-wrap">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="600"
                  height="800"
                  loading="lazy"
                />
              {%- endif -%}
            </div>
            <div class="ss-product-card__info">
              <p class="ss-product-card__name">{{ product.title | escape }}</p>
              <p class="ss-product-card__price">From {{ product.price_min | money }}</p>
            </div>
            <span class="ss-product-card__cta">Shop now</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

{%- comment %} ─── FILTER JS ─── {%- endcomment %}
<script>
  (function () {
    var pills  = document.querySelectorAll('#ss-topics .ss-topic-pill');
    var cards  = document.querySelectorAll('#ss-grid .ss-card');
    var empty  = document.getElementById('ss-empty');

    function filter(tag) {
      var visible = 0;
      cards.forEach(function (card) {
        var tags = (card.dataset.tags || '').split(' ');
        var show = (tag === 'all') || tags.indexOf(tag) > -1;
        card.setAttribute('data-hidden', show ? 'false' : 'true');
        if (show) visible++;
      });
      empty.classList.toggle('is-visible', visible === 0);
    }

    pills.forEach(function (pill) {
      pill.addEventListener('click', function () {
        pills.forEach(function (p) { p.classList.remove('is-active'); });
        this.classList.add('is-active');
        filter(this.dataset.tag);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Story Salon Blog",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Hero tagline",
      "default": "Inspiration, insights, and the art of being. More stories are on their way — pull up a chair."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "More stories coming"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    },
    {
      "type": "header",
      "content": "Product strip"
    },
    {
      "type": "checkbox",
      "id": "show_products",
      "label": "Show 'Worn in the stories' strip",
      "default": true
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    },
    {
      "type": "url",
      "id": "shop_all_url",
      "label": "Shop all link"
    }
  ],
  "presets": [
    {
      "name": "Story Salon Blog"
    }
  ]
}
{% endschema %}
