<style>
  .triiiple-split { display: grid; grid-template-columns: 1.4fr 1fr; min-height: 80vh; background: var(--paper); color: var(--ink); }
  .triiiple-split.reverse { grid-template-columns: 1fr 1.2fr; }
  .split-img-wrap { padding: var(--gut); }
  .split-img-wrap img { width: 100%; height: 100%; max-height: 85vh; object-fit: cover; }
  .split-text { padding: var(--gut); display: flex; flex-direction: column; justify-content: center; align-items: flex-start; gap: 32px; }
  .split-body { font-size: clamp(16px, 2vw, 18px); line-height: 1.6; max-width: 46ch; }
  @media (max-width: 768px) {
    .triiiple-split, .triiiple-split.reverse { grid-template-columns: 1fr; min-height: auto; }
    .split-text { padding-top: 0; }
    .triiiple-split.reverse .split-img-wrap { order: -1; }
  }
</style>

<section class="triiiple-split {% if section.settings.reverse %}reverse{% endif %}" style="background-color: var(--{{ section.settings.bg_color }});">
  {%- capture image_html -%}
    <div class="split-img-wrap triiiple-reveal {% if section.settings.reverse %}stagger-1{% endif %}">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1200 | image_tag }}
      {% else %}
        {{ 'collection-1' | placeholder_svg_tag }}
      {% endif %}
    </div>
  {%- endcapture -%}

  {%- unless section.settings.reverse -%}{{ image_html }}{%- endunless -%}

  <div class="split-text">
    <div class="triiiple-cap triiiple-reveal">{{ section.settings.caption }}</div>
    <h2 class="triiiple-heading text-xlarge triiiple-reveal stagger-1">{{ section.settings.title | newline_to_br }}</h2>
    {% if section.settings.text != blank %}
      <p class="split-body triiiple-reveal stagger-2">{{ section.settings.text }}</p>
    {% endif %}
    {% if section.settings.link_label != blank %}
      <a href="{{ section.settings.link_url }}" class="triiiple-link triiiple-reveal stagger-2">{{ section.settings.link_label }} <span>→</span></a>
    {% endif %}
  </div>

  {%- if section.settings.reverse -%}{{ image_html }}{%- endif -%}
</section>

{% schema %}
{
  "name": "Asymmetric Split",
  "settings": [
    { "type": "select", "id": "bg_color", "label": "Background", "options": [ { "value": "paper", "label": "Paper" }, { "value": "paper-2", "label": "Paper 2" } ], "default": "paper" },
    { "type": "checkbox", "id": "reverse", "label": "Image on Right", "default": false },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "caption", "label": "Caption", "default": "Movement" },
    { "type": "textarea", "id": "title", "label": "Heading", "default": "Draped in\nair and ink." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Our signature poplin is washed for 48 hours..." },
    { "type": "text", "id": "link_label", "label": "Link Label", "default": "Explore" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "presets": [{ "name": "Asymmetric Split" }]
}
{% endschema %}