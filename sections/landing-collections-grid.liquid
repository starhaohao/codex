{%- liquid
  assign heading = section.settings.heading
  assign eyebrow = section.settings.eyebrow
  assign columns = section.settings.columns
  assign bg = section.settings.bg_color
  assign border = section.settings.border_color
  assign text_color = section.settings.text_color
  assign sub_color = section.settings.sub_color
-%}

<section class="lcg" style="--lcg-bg:{{ bg }};--lcg-bd:{{ border }};--lcg-tc:{{ text_color }};--lcg-sc:{{ sub_color }};--lcg-cols:{{ columns }};">
  {%- if heading != blank or eyebrow != blank -%}
    <div class="lcg__header" data-ts-fade style="--ts-delay:0ms">
      {%- if eyebrow != blank -%}<p class="lcg__eyebrow">{{ eyebrow }}</p>{%- endif -%}
      {%- if heading != blank -%}<h2 class="lcg__heading">{{ heading }}</h2>{%- endif -%}
      {%- if section.settings.cta_text != blank -%}
        <a class="lcg__header-cta" href="{{ section.settings.cta_url }}">{{ section.settings.cta_text }} →</a>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="lcg__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign coll = collections[block.settings.collection]
        assign label = block.settings.label | default: coll.title
        assign coll_img = block.settings.image | default: coll.image
        assign link = block.settings.link | default: coll.url
      -%}
      <a class="lcg__item" href="{{ link }}" data-ts-fade style="--ts-delay:{{ forloop.index0 | times: 80 }}ms" {{ block.shopify_attributes }}>
        <div class="lcg__img-wrap">
          {%- if coll_img != blank -%}
            <img class="lcg__img" src="{{ coll_img | image_url: width: 1200 }}" alt="{{ label | escape }}" loading="lazy">
          {%- else -%}
            <div class="lcg__img lcg__img--placeholder"></div>
          {%- endif -%}
          {%- if block.settings.tag != blank -%}
            <span class="lcg__tag">{{ block.settings.tag }}</span>
          {%- endif -%}
        </div>
        <div class="lcg__caption">
          <span class="lcg__name">{{ label }}</span>
          <span class="lcg__arrow">→</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
  /* ── Scroll-fade shared rules ── */
  [data-ts-fade] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.65s cubic-bezier(0.16,1,0.3,1), transform 0.65s cubic-bezier(0.16,1,0.3,1);
    transition-delay: var(--ts-delay, 0ms);
  }
  [data-ts-fade].ts-visible { opacity: 1; transform: none; }

  .lcg {
    overflow-x: hidden;
    box-sizing: border-box;
    max-width: 100%;
    padding: 64px 40px;
    background: var(--lcg-bg);
  }
  .lcg__header {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .lcg__eyebrow {
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #923531;
    margin: 0;
  }
  .lcg__heading {
    font-size: clamp(22px, 2.8vw, 36px);
    font-weight: 400;
    letter-spacing: -0.04em;
    color: var(--lcg-tc);
    margin: 0;
    flex: 1;
  }
  .lcg__header-cta {
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--lcg-sc);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.2);
    padding-bottom: 2px;
    transition: border-color 0.2s;
    white-space: nowrap;
  }
  .lcg__header-cta:hover { border-color: rgba(255,255,255,0.6); }
  .lcg__grid {
    display: grid;
    grid-template-columns: repeat(var(--lcg-cols), 1fr);
    gap: 2px;
  }
  .lcg__item {
    display: block;
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }
  .lcg__img-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }
  .lcg__img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.55s cubic-bezier(0.25,0,0,1);
    display: block;
  }
  .lcg__img--placeholder { background: #1a1d20; }
  .lcg__item:hover .lcg__img { transform: scale(1.04); }
  .lcg__tag {
    position: absolute;
    top: 14px; left: 14px;
    font-family: monospace;
    font-size: 8px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: #923531;
    color: #fff;
    padding: 4px 8px;
  }
  .lcg__caption {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0 0;
  }
  .lcg__name {
    font-size: 14px;
    letter-spacing: -0.01em;
    color: var(--lcg-tc);
  }
  .lcg__arrow {
    font-size: 14px;
    color: var(--lcg-sc);
    transition: transform 0.2s;
  }
  .lcg__item:hover .lcg__arrow { transform: translateX(4px); }
  @media (max-width: 989px) {
    .lcg { padding: 48px 24px; }
    .lcg__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 749px) {
    .lcg { padding: 40px 16px; }
    .lcg__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

{% schema %}
{
  "name": "Collections Grid",
  "tag": "div",
  "class": "landing-collections-grid-section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#1a1d20" },
    { "type": "color", "id": "border_color", "label": "Border", "default": "rgba(255,255,255,0.11)" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "sub_color", "label": "Secondary color", "default": "rgba(255,255,255,0.42)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by Category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collections" },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "text", "id": "cta_text", "label": "View all CTA", "default": "View All" },
    { "type": "url", "id": "cta_url", "label": "View all link" }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Override image" },
        { "type": "text", "id": "label", "label": "Override label" },
        { "type": "text", "id": "tag", "label": "Badge", "info": "e.g. New, Best Seller" },
        { "type": "url", "id": "link", "label": "Override link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections Grid",
      "blocks": [
        { "type": "collection_card", "settings": { "label": "Briefs", "tag": "Best Seller" } },
        { "type": "collection_card", "settings": { "label": "Boxer Trunks" } },
        { "type": "collection_card", "settings": { "label": "Tops", "tag": "New" } }
      ]
    }
  ],
  "templates": ["index", "page"]
}
{% endschema %}
