{% liquid
  assign rating = blank
  assign scale_max = 5
  assign rating_count = blank

  if product != blank and product.metafields.reviews.rating.value.rating != blank
    assign rating = product.metafields.reviews.rating.value.rating
    assign scale_max = product.metafields.reviews.rating.value.scale_max | default: 5
    assign rating_count = product.metafields.reviews.rating_count
  endif
%}

<section
  class="triiiple-editorial-conversion"
  style="
    --conversion-bg: {{ section.settings.background_color }};
    --conversion-ink: {{ section.settings.text_color }};
    --conversion-accent: {{ section.settings.accent_color }};
  "
>
  <div class="triiiple-editorial-conversion__inner">
    <header class="triiiple-editorial-conversion__header">
      {% if section.settings.eyebrow != blank %}
        <p class="triiiple-editorial-conversion__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      <div class="triiiple-editorial-conversion__heading">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading | escape }}</h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="rte">{{ section.settings.description }}</div>
        {% endif %}
      </div>
    </header>

    <div class="triiiple-editorial-conversion__grid">
      <article class="triiiple-editorial-conversion__card triiiple-editorial-conversion__card--signup">
        {% if section.settings.form_heading != blank %}
          <p class="triiiple-editorial-conversion__card-eyebrow">{{ section.settings.form_eyebrow | escape }}</p>
          <h3>{{ section.settings.form_heading | escape }}</h3>
        {% endif %}

        {% if section.settings.form_text != blank %}
          <p class="triiiple-editorial-conversion__card-text">{{ section.settings.form_text | escape }}</p>
        {% endif %}

        {%- form 'customer', class: 'triiiple-editorial-conversion__form' -%}
          <input type="hidden" name="contact[tags]" value="{{ section.settings.tag_label | escape }}">

          <label class="visually-hidden" for="EditorialConversionEmail-{{ section.id }}">
            {{ 'blocks.email_signup.label' | t }}
          </label>
          <div class="triiiple-editorial-conversion__input-row">
            <input
              id="EditorialConversionEmail-{{ section.id }}"
              class="triiiple-editorial-conversion__input"
              type="email"
              name="contact[email]"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              required
              placeholder="{{ 'blocks.email_signup.placeholder' | t }}"
              {% if form.errors %}
                aria-invalid="true"
              {% endif %}
            >
            <button class="triiiple-editorial-conversion__submit" type="submit">
              {{ section.settings.button_label | escape }}
            </button>
          </div>

          {%- if form.errors -%}
            <p class="triiiple-editorial-conversion__message triiiple-editorial-conversion__message--error" role="alert">
              {{ form.errors.messages.email | default: form.errors | default_errors }}
            </p>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <p class="triiiple-editorial-conversion__message triiiple-editorial-conversion__message--success" role="status">
              {{ 'blocks.email_signup.success' | t }}
            </p>
          {%- endif -%}
        {%- endform -%}

        {% if section.settings.form_note != blank %}
          <p class="triiiple-editorial-conversion__note">{{ section.settings.form_note | escape }}</p>
        {% endif %}
      </article>

      <article class="triiiple-editorial-conversion__card triiiple-editorial-conversion__card--reviews">
        {% if section.settings.review_eyebrow != blank %}
          <p class="triiiple-editorial-conversion__card-eyebrow">{{ section.settings.review_eyebrow | escape }}</p>
        {% endif %}

        {% if section.settings.review_heading != blank %}
          <h3>{{ section.settings.review_heading | escape }}</h3>
        {% endif %}

        {% if section.settings.review_liquid != blank %}
          <div class="triiiple-editorial-conversion__embed">
            {{ section.settings.review_liquid }}
          </div>
        {% elsif rating != blank and section.settings.show_product_rating %}
          <div
            class="triiiple-editorial-conversion__rating"
            aria-label="{{ 'accessibility.rating' | t: rating: rating }}"
          >
            <span class="triiiple-editorial-conversion__rating-value">{{ rating | round: 1 }}/{{ scale_max }}</span>
            {% if rating_count != blank %}
              <span class="triiiple-editorial-conversion__rating-count">{{ rating_count }} reviews</span>
            {% endif %}
          </div>
          {% if section.settings.review_text != blank %}
            <div class="triiiple-editorial-conversion__card-text rte">{{ section.settings.review_text }}</div>
          {% endif %}
        {% else %}
          {% if section.settings.review_text != blank %}
            <div class="triiiple-editorial-conversion__card-text rte">{{ section.settings.review_text }}</div>
          {% endif %}

          {% if section.settings.review_button_label != blank and section.settings.review_button_url != blank %}
            <a class="triiiple-editorial-conversion__button" href="{{ section.settings.review_button_url }}">
              {{ section.settings.review_button_label | escape }}
            </a>
          {% endif %}
        {% endif %}
      </article>
    </div>
  </div>
</section>

{% stylesheet %}
  .triiiple-editorial-conversion {
    background: var(--conversion-bg, #fff);
    color: var(--conversion-ink, #17191c);
  }

  .triiiple-editorial-conversion__inner {
    width: min(100%, var(--page-width));
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 4rem) var(--page-margin) clamp(3rem, 7vw, 6rem);
  }

  .triiiple-editorial-conversion__header {
    display: grid;
    gap: 1rem;
    padding-bottom: clamp(1.5rem, 4vw, 2.5rem);
    border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    padding-top: clamp(1.25rem, 3vw, 2rem);
  }

  .triiiple-editorial-conversion__eyebrow,
  .triiiple-editorial-conversion__card-eyebrow {
    margin: 0;
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.58;
  }

  .triiiple-editorial-conversion__heading {
    display: grid;
    gap: 0.9rem;
    max-width: 44rem;
  }

  .triiiple-editorial-conversion__heading h2,
  .triiiple-editorial-conversion__card h3 {
    margin: 0;
    font-family: var(--font-body--family);
    font-weight: 400;
    letter-spacing: -0.03em;
  }

  .triiiple-editorial-conversion__heading h2 {
    font-size: clamp(1.9rem, 4vw, 4rem);
    line-height: 0.95;
  }

  .triiiple-editorial-conversion__heading .rte {
    max-width: 38rem;
    font-size: 1rem;
    line-height: 1.75;
  }

  .triiiple-editorial-conversion__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .triiiple-editorial-conversion__card {
    display: grid;
    gap: 1rem;
    align-content: start;
    padding: clamp(1.2rem, 2.8vw, 2rem);
    border: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    background: #fff;
  }

  .triiiple-editorial-conversion__card h3 {
    font-size: clamp(1.2rem, 1.7vw, 1.8rem);
  }

  .triiiple-editorial-conversion__card-text,
  .triiiple-editorial-conversion__note {
    margin: 0;
    font-size: 0.94rem;
    line-height: 1.7;
    opacity: 0.74;
  }

  .triiiple-editorial-conversion__form {
    display: grid;
    gap: 0.75rem;
  }

  .triiiple-editorial-conversion__input-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
  }

  .triiiple-editorial-conversion__input,
  .triiiple-editorial-conversion__submit,
  .triiiple-editorial-conversion__button {
    min-height: 3rem;
    border: 1px solid currentColor;
    border-radius: 0;
    font: inherit;
  }

  .triiiple-editorial-conversion__input {
    padding: 0 0.95rem;
    background: #fff;
    color: inherit;
  }

  .triiiple-editorial-conversion__input::placeholder {
    color: color-mix(in srgb, currentColor 50%, transparent);
  }

  .triiiple-editorial-conversion__submit,
  .triiiple-editorial-conversion__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.2rem;
    background: var(--conversion-ink, #17191c);
    color: var(--conversion-bg, #fff);
    text-decoration: none;
  }

  .triiiple-editorial-conversion__message {
    margin: 0;
    font-size: 0.85rem;
  }

  .triiiple-editorial-conversion__message--error {
    color: #8a1f11;
  }

  .triiiple-editorial-conversion__message--success {
    color: #1d5b3f;
  }

  .triiiple-editorial-conversion__embed {
    display: grid;
    gap: 0.75rem;
  }

  .triiiple-editorial-conversion__rating {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .triiiple-editorial-conversion__rating-value {
    padding: 0.25rem 0.5rem;
    border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
  }

  .triiiple-editorial-conversion__rating-count {
    font-size: 0.88rem;
    opacity: 0.72;
  }

  @media screen and (max-width: 749px) {
    .triiiple-editorial-conversion__inner {
      padding-inline: 1rem;
    }

    .triiiple-editorial-conversion__grid,
    .triiiple-editorial-conversion__input-row {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial conversion",
  "enabled_on": {
    "templates": [
      "index",
      "product"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sharp updates, clean fit notes."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Use this space for the native Shopify signup and a Klaviyo-ready review or embed slot, kept in the same white editorial language as the rest of the site.</p>"
    },
    {
      "type": "header",
      "content": "Signup"
    },
    {
      "type": "text",
      "id": "form_eyebrow",
      "label": "Signup eyebrow",
      "default": "Shopify form"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Signup heading",
      "default": "Join for drops, edits, and fit updates."
    },
    {
      "type": "text",
      "id": "form_text",
      "label": "Signup text",
      "default": "First access, new stories, and practical product notes."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Sign up"
    },
    {
      "type": "text",
      "id": "tag_label",
      "label": "Customer tag",
      "default": "newsletter"
    },
    {
      "type": "text",
      "id": "form_note",
      "label": "Signup note",
      "default": "Short, useful, and never too often."
    },
    {
      "type": "header",
      "content": "Reviews"
    },
    {
      "type": "text",
      "id": "review_eyebrow",
      "label": "Review eyebrow",
      "default": "Klaviyo review area"
    },
    {
      "type": "text",
      "id": "review_heading",
      "label": "Review heading",
      "default": "Bring in the review widget here."
    },
    {
      "type": "richtext",
      "id": "review_text",
      "label": "Review text",
      "default": "<p>This card can hold your Klaviyo review embed or show the product rating summary on product pages.</p>"
    },
    {
      "type": "liquid",
      "id": "review_liquid",
      "label": "Review embed code"
    },
    {
      "type": "checkbox",
      "id": "show_product_rating",
      "label": "Show product rating when available",
      "default": true
    },
    {
      "type": "text",
      "id": "review_button_label",
      "label": "Review button label",
      "default": "Read Story Salon"
    },
    {
      "type": "url",
      "id": "review_button_url",
      "label": "Review button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#17191c"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#4a1024"
    }
  ],
  "presets": [
    {
      "name": "Editorial conversion",
      "category": "Layout"
    }
  ]
}
{% endschema %}
