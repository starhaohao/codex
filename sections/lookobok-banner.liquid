{%- liquid
  assign bg = section.settings.bg_color
  assign eyebrow_color = section.settings.eyebrow_color
  assign title_color = section.settings.title_color
  assign overlay_strength = section.settings.overlay_strength
  assign title_size = section.settings.title_size
  assign banner_height = section.settings.banner_height
  assign img_opacity = section.settings.img_opacity
-%}
<div class="lbn" style="--lbn-bg:{{ bg }};--lbn-ec:{{ eyebrow_color }};--lbn-tc:{{ title_color }};--lbn-ov:{{ overlay_strength }};--lbn-ts:{{ title_size }}px;--lbn-h:{{ banner_height }}vh;--lbn-io:{{ img_opacity }};">
  {%- if section.settings.image != blank -%}
    <img class="lbn__img" src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.image.alt | escape }}" loading="eager">
  {%- endif -%}
  <div class="lbn__overlay"></div>
  <div class="lbn__content">
    <div class="lbn__eyebrow">{{ section.settings.eyebrow }}</div>
    <h1 class="lbn__title">{{ section.settings.title }}</h1>
  </div>
</div>

<style>
  .lbn { position:relative; height:var(--lbn-h); min-height:240px; max-height:520px; overflow:hidden; background:var(--lbn-bg); }
  .lbn__img { width:100%; height:100%; object-fit:cover; object-position:center 22%; display:block; opacity:var(--lbn-io); }
  .lbn__overlay { position:absolute; inset:0; background:linear-gradient(to top, rgba(17,18,20,var(--lbn-ov)) 0%, rgba(17,18,20,0.08) 65%); }
  .lbn__content { position:absolute; bottom:36px; left:40px; right:40px; }
  .lbn__eyebrow { font-family:monospace; font-size:9px; text-transform:uppercase; letter-spacing:0.2em; color:var(--lbn-ec); margin-bottom:8px; }
  .lbn__title { font-size:var(--lbn-ts); letter-spacing:-0.04em; line-height:0.95; color:var(--lbn-tc); font-weight:400; }
  @media (max-width:749px){ .lbn__content{ bottom:24px; left:20px; right:20px; } .lbn__title{ font-size:calc(var(--lbn-ts) * 0.6); } }
</style>

{% schema %}
{
  "name": "Lookbook Banner",
  "tag": "section",
  "class": "lookbook-banner-section",
  "settings": [
    { "type":"image_picker","id":"image","label":"Banner image" },
    { "type":"color","id":"bg_color","label":"Fallback background","default":"#111214" },
    { "type":"color","id":"eyebrow_color","label":"Eyebrow color","default":"rgba(255,255,255,0.45)" },
    { "type":"color","id":"title_color","label":"Title color","default":"#ffffff" },
    { "type":"range","id":"overlay_strength","label":"Overlay strength","min":0,"max":1,"step":0.1,"default":0.8 },
    { "type":"range","id":"title_size","label":"Title size (px)","min":32,"max":120,"step":2,"default":72 },
    { "type":"range","id":"banner_height","label":"Height (vh)","min":30,"max":80,"step":2,"default":48 },
    { "type":"range","id":"img_opacity","label":"Image opacity","min":0.3,"max":1,"step":0.1,"default":0.7 },
    { "type":"text","id":"eyebrow","label":"Eyebrow","default":"Studio Collection · 2025" },
    { "type":"text","id":"title","label":"Title","default":"Shop All." }
  ],
  "presets":[{ "name":"Lookbook Banner" }],
  "templates":["page"]
}
{% endschema %}