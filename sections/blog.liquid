<!-- /sections/blog.liquid -- TRIIIPLE Story Salon edition -->
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign article_limit = section.settings.rows | times: 3 | plus: 2
-%}

<style>
  .ts-nav {
    display: flex;
    align-items: center;
    padding: 0 var(--outer, 16px);
    border-bottom: 1px solid var(--COLOR-BORDER);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .ts-nav::-webkit-scrollbar { display: none; }
  .ts-nav__link {
    display: block;
    flex-shrink: 0;
    padding: 16px 18px;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--COLOR-TEXT-A40, #bbb);
    text-decoration: none;
    white-space: nowrap;
    position: relative;
    transition: color 0.2s;
  }
  .ts-nav__link:hover { color: var(--COLOR-TEXT, #111); }
  .ts-nav__link.is-active { color: var(--COLOR-TEXT, #111); }
  .ts-nav__link.is-active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 18px;
    right: 18px;
    height: 1px;
    background: var(--COLOR-TEXT, #111);
  }
  .ts-feature-wrap {
    padding: 32px var(--outer, 16px) 52px;
    border-bottom: 1px solid var(--COLOR-BORDER);
  }
  .ts-feature {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }
  .ts-feature-card { display: block; text-decoration: none; color: inherit; }
  .ts-feature-card__image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--COLOR-BG-SECONDARY, #f0f0f0);
    margin-bottom: 16px;
  }
  .ts-feature-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .ts-feature-card:hover .ts-feature-card__image img { transform: scale(1.04); }
  .ts-feature-card__tag {
    display: inline-block;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--COLOR-TEXT-A50, #aaa);
    border: 1px solid var(--COLOR-BORDER);
    padding: 4px 8px;
    margin-bottom: 10px;
    line-height: 1;
  }
  .ts-feature-card__title {
    font-family: 'Galdeano', serif;
    font-size: clamp(18px, 2.2vw, 28px);
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 10px;
    color: var(--COLOR-TEXT, #111);
  }
  .ts-feature-card__excerpt {
    font-size: 13px;
    line-height: 1.7;
    color: var(--COLOR-TEXT-A60, #888);
    margin: 0 0 12px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ts-feature-card__cta {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--COLOR-TEXT, #111);
  }
  .ts-feature-card:hover .ts-feature-card__cta { opacity: 0.55; }
  .ts-grid-wrap { padding: 48px var(--outer, 16px) 80px; }
  .ts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 52px 28px;
  }
  .ts-card { display: block; text-decoration: none; color: inherit; }
  .ts-card__tag {
    display: inline-block;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--COLOR-TEXT-A50, #aaa);
    border: 1px solid var(--COLOR-BORDER);
    padding: 4px 8px;
    margin-bottom: 10px;
    line-height: 1;
  }
  .ts-card__image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--COLOR-BG-SECONDARY, #f0f0f0);
    margin-bottom: 14px;
  }
  .ts-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .ts-card:hover .ts-card__image img { transform: scale(1.04); }
  .ts-card__title {
    font-family: 'Galdeano', serif;
    font-size: clamp(15px, 1.4vw, 19px);
    font-weight: 400;
    line-height: 1.25;
    margin: 0 0 8px;
    color: var(--COLOR-TEXT, #111);
  }
  .ts-card__excerpt {
    font-size: 13px;
    line-height: 1.7;
    color: var(--COLOR-TEXT-A60, #888);
    margin: 0 0 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ts-card__cta {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--COLOR-TEXT, #111);
  }
  .ts-card:hover .ts-card__cta { opacity: 0.55; }
  @media screen and (max-width: 749px) {
    .ts-feature-wrap { padding: 24px 0 36px; }
    .ts-feature {
      display: flex;
      grid-template-columns: none;
      gap: 16px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 var(--outer, 16px);
    }
    .ts-feature::-webkit-scrollbar { display: none; }
    .ts-feature-card { flex: 0 0 84%; scroll-snap-align: start; }
    .ts-feature-card__image { aspect-ratio: 4 / 5; }
    .ts-grid-wrap { padding: 32px 0 60px; }
    .ts-grid {
      display: flex;
      grid-template-columns: none;
      gap: 16px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 var(--outer, 16px);
    }
    .ts-grid::-webkit-scrollbar { display: none; }
    .ts-card { flex: 0 0 75%; scroll-snap-align: start; }
    .ts-card__image { aspect-ratio: 3 / 4; }
  }
</style>

<section id="Blog--{{ section.id }}" class="ts-blog {{ color_scheme }}">
  <nav class="ts-nav" role="navigation" aria-label="Blog categories">
    <a href="{{ blog.url }}" class="ts-nav__link{% unless current_tags %} is-active{% endunless %}">All</a>
    {%- for tag in blog.all_tags -%}
      <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="ts-nav__link{% if current_tags contains tag %} is-active{% endif %}">{{ tag }}</a>
    {%- endfor -%}
  </nav>

  {%- paginate blog.articles by article_limit -%}

  {%- if blog.articles.size > 0 -%}
  <div class="ts-feature-wrap">
    <div class="ts-feature">
      {%- for article in blog.articles limit: 2 -%}
        <a href="{{ article.url }}" class="ts-feature-card">
          <div class="ts-feature-card__image">
            {%- if article.image -%}
              {{ article.image | image_url: width: 1400 | image_tag: loading: 'eager', sizes: '(max-width: 749px) 85vw, 50vw' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          {%- if article.tags.size > 0 -%}
            <span class="ts-feature-card__tag">{{ article.tags.first }}</span>
          {%- endif -%}
          <h2 class="ts-feature-card__title">{{ article.title }}</h2>
          <p class="ts-feature-card__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 25 }}</p>
          <span class="ts-feature-card__cta">Read More</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}

  {%- if blog.articles.size > 2 -%}
  <div class="ts-grid-wrap">
    <div class="ts-grid">
      {%- for article in blog.articles offset: 2 -%}
        <a href="{{ article.url }}" class="ts-card">
          {%- if article.tags.size > 0 -%}
            <span class="ts-card__tag">{{ article.tags.first }}</span>
          {%- endif -%}
          <div class="ts-card__image">
            {%- if article.image -%}
              {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(max-width: 749px) 76vw, 33vw' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <h3 class="ts-card__title">{{ article.title }}</h3>
          <p class="ts-card__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 18 }}</p>
          <span class="ts-card__cta">Read More</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}

  {%- render 'pagination', paginate: paginate -%}
  {%- endpaginate -%}
</section>

{% schema %}
{
  "name": "Blog pages",
  "settings": [
    { "type": "range", "id": "rows", "min": 1, "max": 6, "step": 1, "label": "Rows of articles (after feature)", "default": 2 },
    { "type": "color_scheme", "id": "color_scheme", "default": "scheme_1", "label": "Color scheme" }
  ]
}
{% endschema %}
