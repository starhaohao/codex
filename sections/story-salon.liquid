<section class="story-salon" data-story-salon style="--salon-ink: {{ section.settings.ink }}; --salon-paper: {{ section.settings.paper }}; --salon-accent: {{ section.settings.accent }};">
  <div class="story-salon__mosaic">
    {% for i in (1..5) %}
      {% liquid
        assign image_key = 'hero_image_' | append: i
        assign hero_image = section.settings[image_key]
      %}
      <div class="story-salon__tile story-salon__tile--{{ i }}">
        {% if hero_image != blank %}{{ hero_image | image_url: width: 1200 | image_tag: widths: '400, 700, 1000, 1200', sizes: '(min-width: 750px) 20vw, 50vw', loading: 'eager', alt: section.settings.hero_title }}{% endif %}
      </div>
    {% endfor %}
    <div class="story-salon__title"><p>{{ section.settings.hero_eyebrow | escape }}</p><h1>{{ section.settings.hero_title | escape }}</h1></div>
  </div>

  <div class="story-salon__journal" id="stories">
    <header class="story-salon__intro">
      <div>
        <h2>{{ section.settings.intro_heading | newline_to_br }}</h2>
        {% if section.settings.intro_text != blank %}<div class="rte">{{ section.settings.intro_text }}</div>{% endif %}
      </div>
      <div class="story-salon__filters" aria-label="Story filters">
        <button type="button" aria-pressed="true" data-story-filter="all">{{ section.settings.all_label | escape }}</button>
        <button type="button" aria-pressed="false" data-story-filter="first">{{ section.settings.first_label | escape }}</button>
        <button type="button" aria-pressed="false" data-story-filter="raw">{{ section.settings.raw_label | escape }}</button>
      </div>
    </header>

    <div class="story-salon__grid">
      {% for block in section.blocks %}
        {% if block.type == 'story' %}
          <a class="story-card" data-story-card data-category="{{ block.settings.category }}" href="{{ block.settings.link | default: '#stories' }}" {{ block.shopify_attributes }}>
            <div class="story-card__media">
              {% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 1000 | image_tag: widths: '400, 700, 1000', sizes: '(min-width: 900px) 25vw, 50vw', loading: 'lazy', alt: block.settings.name }}{% endif %}
              <span class="story-card__series">{{ block.settings.series | escape }}</span>
              <span class="story-card__name">{{ block.settings.name | escape }}</span>
            </div>
            <div class="story-card__caption">
              <h3>{{ block.settings.title | escape }}</h3>
              <p>{{ block.settings.description | escape }}</p>
              <span>{{ section.settings.explore_label | escape }} <span aria-hidden="true">&#8594;</span></span>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>

    <div class="story-salon__spotlight">
      <header><span>{{ section.settings.spotlight_heading | escape }}</span><span>{{ section.settings.spotlight_label | escape }}</span></header>
      <div class="story-salon__looks">
        {% for block in section.blocks %}
          {% if block.type == 'spotlight' %}
            <a class="story-look" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
              <div>{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 1000 | image_tag: widths: '400, 700, 1000', sizes: '(min-width: 900px) 25vw, 50vw', loading: 'lazy', alt: block.settings.person }}{% endif %}<span>{{ block.settings.fabric | escape }}</span></div>
              <p>{{ block.settings.series | escape }}</p>
              <h3>{{ block.settings.person | escape }}</h3>
              <span>{{ block.settings.product | escape }}</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% javascript %}
  document.querySelectorAll('[data-story-salon]').forEach((section) => {
    const buttons = section.querySelectorAll('[data-story-filter]');
    const cards = section.querySelectorAll('[data-story-card]');
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.storyFilter;
        buttons.forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
        cards.forEach((card) => { card.hidden = filter !== 'all' && card.dataset.category !== filter; });
      });
    });
  });
{% endjavascript %}

{% stylesheet %}
  .story-salon { background: var(--salon-paper, #fff); color: var(--salon-ink, #0f1623); }
  .story-salon__mosaic { position: relative; display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); min-height: clamp(24rem, 52vw, 50rem); overflow: hidden; background: var(--salon-ink); }
  .story-salon__tile { min-width: 0; overflow: hidden; }
  .story-salon__tile img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.82) contrast(1.03); transition: transform 700ms cubic-bezier(.2,.7,.2,1); }
  .story-salon__tile:nth-child(even) { padding: 8% 12%; }
  .story-salon__tile:nth-child(even) img { object-fit: contain; }
  .story-salon__mosaic:hover .story-salon__tile img { transform: scale(1.015); }
  .story-salon__title { position: absolute; inset: auto var(--page-margin) clamp(1.5rem, 4vw, 4rem); z-index: 2; color: #fff; text-align: right; pointer-events: none; }
  .story-salon__title p { margin: 0 0 0.5rem; font-size: 0.66rem; letter-spacing: 0.2em; text-transform: uppercase; }
  .story-salon__title h1 { margin: 0; font-family: var(--font-heading--family); font-size: clamp(2rem, 7vw, 6rem); line-height: 0.82; letter-spacing: -0.025em; }
  .story-salon__journal { max-width: var(--page-width); margin: 0 auto; }
  .story-salon__intro { display: flex; justify-content: space-between; align-items: end; gap: 2rem; padding: clamp(2.5rem, 6vw, 6rem) var(--page-margin) 2rem; }
  .story-salon__intro h2 { margin: 0; max-width: 34ch; font-family: var(--font-body--family); font-size: clamp(1.25rem, 2.2vw, 2rem); font-weight: 400; line-height: 1.05; }
  .story-salon__intro .rte { max-width: 44rem; margin-top: 1rem; opacity: 0.68; }
  .story-salon__filters { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .story-salon__filters button { padding: 0.65rem 1rem; border: 1px solid color-mix(in srgb, currentColor 25%, transparent); border-radius: 99px; color: inherit; background: transparent; font: inherit; font-size: 0.68rem; text-transform: uppercase; cursor: pointer; }
  .story-salon__filters button[aria-pressed='true'] { color: var(--salon-paper); background: var(--salon-ink); }
  .story-salon__grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .story-card { display: flex; min-width: 0; flex-direction: column; color: inherit; text-decoration: none; border-inline-end: 1px solid currentColor; }
  .story-card:nth-child(4n) { border-inline-end: 0; }
  .story-card[hidden] { display: none; }
  .story-card__media { position: relative; aspect-ratio: 4 / 5; overflow: hidden; background: #dfe1e3; }
  .story-card__media::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgb(15 11 8 / 0.64), transparent 55%); }
  .story-card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 500ms ease; }
  .story-card:hover img { transform: scale(1.025); }
  .story-card__series, .story-card__name { position: absolute; z-index: 1; left: 1rem; color: #fff; }
  .story-card__series { top: 1rem; font-size: 0.58rem; letter-spacing: 0.16em; text-transform: uppercase; }
  .story-card__name { bottom: 1rem; font-family: var(--font-heading--family); font-size: clamp(1.1rem, 2vw, 2rem); }
  .story-card__caption { padding: 1rem 1rem 1.75rem; }
  .story-card__caption h3 { margin: 0; font-family: var(--font-body--family); font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; }
  .story-card__caption p { min-height: 4.5em; margin: 0.5rem 0 0; font-size: 0.76rem; line-height: 1.48; opacity: 0.68; }
  .story-card__caption > span { display: inline-block; margin-top: 0.8rem; color: var(--salon-accent); font-size: 0.65rem; text-transform: uppercase; }
  .story-salon__spotlight { padding: clamp(3rem, 7vw, 7rem) var(--page-margin); border-top: 1px solid color-mix(in srgb, currentColor 15%, transparent); }
  .story-salon__spotlight > header { display: flex; justify-content: space-between; padding-bottom: 1rem; border-bottom: 1px solid currentColor; font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase; }
  .story-salon__looks { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; padding-top: 1.5rem; }
  .story-look { color: inherit; text-decoration: none; }
  .story-look > div { position: relative; aspect-ratio: 4 / 5; overflow: hidden; background: #dfe1e3; }
  .story-look img { width: 100%; height: 100%; object-fit: cover; transition: transform 500ms ease; }
  .story-look:hover img { transform: scale(1.025); }
  .story-look > div span { position: absolute; inset: 0.8rem auto auto 0.8rem; padding: 0.35rem 0.5rem; color: #fff; background: var(--salon-ink); font-size: 0.58rem; text-transform: uppercase; }
  .story-look > p { margin: 0.8rem 0 0; font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.55; }
  .story-look h3 { margin: 0.25rem 0; font-family: var(--font-heading--family); font-size: 1.15rem; }
  .story-look > span { font-size: 0.78rem; opacity: 0.72; }
  @media screen and (max-width: 899px) { .story-salon__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .story-card:nth-child(4n) { border-inline-end: 1px solid currentColor; } .story-card:nth-child(2n) { border-inline-end: 0; } .story-salon__looks { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media screen and (max-width: 749px) { .story-salon__mosaic { grid-template-columns: repeat(2, 1fr); min-height: 34rem; } .story-salon__tile:last-of-type { display: none; } .story-salon__title { inset-inline: 1rem; } .story-salon__title h1 { font-size: clamp(2rem, 15vw, 4.5rem); } .story-salon__intro { display: grid; padding-inline: 1rem; } .story-salon__spotlight { padding-inline: 1rem; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Story Salon",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    { "type": "image_picker", "id": "hero_image_1", "label": "Hero image 1" }, { "type": "image_picker", "id": "hero_image_2", "label": "Hero image 2" }, { "type": "image_picker", "id": "hero_image_3", "label": "Hero image 3" }, { "type": "image_picker", "id": "hero_image_4", "label": "Hero image 4" }, { "type": "image_picker", "id": "hero_image_5", "label": "Hero image 5" },
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "The TRIIIPLE Journal" }, { "type": "text", "id": "hero_title", "label": "Hero title", "default": "Story Salon" },
    { "type": "textarea", "id": "intro_heading", "label": "Introduction heading", "default": "not a campaign. not a lookbook.\na room where people sit down and say something true." },
    { "type": "richtext", "id": "intro_text", "label": "Introduction text" },
    { "type": "text", "id": "all_label", "label": "All filter", "default": "All" }, { "type": "text", "id": "first_label", "label": "First Layer filter", "default": "The 1st Layer" }, { "type": "text", "id": "raw_label", "label": "Raw filter", "default": "Raw n Uncut" }, { "type": "text", "id": "explore_label", "label": "Card link label", "default": "Explore" },
    { "type": "text", "id": "spotlight_heading", "label": "Spotlight heading", "default": "What They Wear" }, { "type": "text", "id": "spotlight_label", "label": "Spotlight label", "default": "Spotlight" },
    { "type": "color", "id": "paper", "label": "Paper", "default": "#ffffff" }, { "type": "color", "id": "ink", "label": "Ink", "default": "#0f1623" }, { "type": "color", "id": "accent", "label": "Accent", "default": "#923531" }
  ],
  "blocks": [
    { "type": "story", "name": "Story", "settings": [{ "type": "select", "id": "category", "label": "Category", "options": [{ "value": "first", "label": "The First Layer" }, { "value": "raw", "label": "Raw n Uncut" }], "default": "first" }, { "type": "text", "id": "series", "label": "Series", "default": "The First Layer" }, { "type": "text", "id": "name", "label": "Name" }, { "type": "text", "id": "title", "label": "Story title" }, { "type": "textarea", "id": "description", "label": "Description" }, { "type": "image_picker", "id": "image", "label": "Portrait" }, { "type": "url", "id": "link", "label": "Story link" }] },
    { "type": "spotlight", "name": "What they wear", "settings": [{ "type": "image_picker", "id": "image", "label": "Image" }, { "type": "text", "id": "fabric", "label": "Fabric" }, { "type": "text", "id": "series", "label": "Series" }, { "type": "text", "id": "person", "label": "Person" }, { "type": "text", "id": "product", "label": "Product" }, { "type": "url", "id": "link", "label": "Product link" }] }
  ],
  "max_blocks": 20,
  "presets": [{ "name": "Story Salon" }]
}
{% endschema %}
