{% liquid
  assign story_blog = section.settings.blog

  if story_blog == blank
    assign story_blog = blogs['story-salon']
  endif

  assign story_articles = story_blog.articles
  assign story_count = story_articles.size
  assign first_story = blank
  assign second_story = blank

  for story_article in story_articles
    if story_article.tags contains 'featured'
      assign first_story = story_article
    elsif story_article.tags contains 'secondary'
      assign second_story = story_article
    endif
  endfor

  if first_story == blank or second_story == blank
    for story_article in story_articles
      if first_story == blank
        assign first_story = story_article
      elsif second_story == blank and story_article.id != first_story.id
        assign second_story = story_article
      endif
    endfor
  endif
%}

<section
  class="story-salon"
  data-story-salon
  style="
    --salon-ink: {{ section.settings.ink }};
    --salon-paper: {{ section.settings.paper }};
    --salon-accent: {{ section.settings.accent }};
  "
>
  <div class="story-salon__frame">
    <header class="story-salon__bar">
      <span>TRIIIPLE Studio</span>
      <span>Story Salon / {{ story_count }} stories</span>
    </header>

    <div class="story-salon__mosaic">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'hero_image_' | append: i
          assign hero_image = section.settings[image_key]
        %}
        <div class="story-salon__tile story-salon__tile--{{ i }}">
          {% if hero_image != blank %}
            {{
              hero_image
              | image_url: width: 1200
              | image_tag:
                widths: '400, 700, 1000, 1200',
                sizes: '(min-width: 750px) 20vw, 50vw',
                loading: 'eager',
                alt: section.settings.hero_title
            }}
          {% endif %}
        </div>
      {% endfor %}

      <div class="story-salon__title">
        <p>{{ section.settings.hero_eyebrow | escape }}</p>
        <h1>{{ section.settings.hero_title | escape }}</h1>
        {% if section.settings.hero_lede != blank %}
          <p class="story-salon__lede">{{ section.settings.hero_lede }}</p>
        {% endif %}
      </div>
    </div>

    <div class="story-salon__journal" id="stories">
      <header class="story-salon__intro">
        <div class="story-salon__intro-heading">
          <p class="story-salon__intro-eyebrow">Editorial room</p>
          <h2>{{ section.settings.intro_heading | newline_to_br }}</h2>
        </div>

        <div class="story-salon__intro-copy">
          {% if section.settings.intro_text != blank %}
            <div class="story-salon__intro-text rte">{{ section.settings.intro_text }}</div>
          {% endif %}

          <div class="story-salon__filters" aria-label="Story filters">
            <button type="button" aria-pressed="true" data-story-filter="all">
              {{ section.settings.all_label | escape }}
            </button>
            <button type="button" aria-pressed="false" data-story-filter="first">
              {{ section.settings.first_label | escape }}
            </button>
            <button type="button" aria-pressed="false" data-story-filter="raw">
              {{ section.settings.raw_label | escape }}
            </button>
          </div>
        </div>
      </header>

      {% if first_story != blank %}
        {% liquid
          assign first_series = section.settings.first_label
          if first_story.tags contains 'raw'
            assign first_series = section.settings.raw_label
          endif
          assign first_summary = first_story.excerpt_or_content | strip_html | strip_newlines | truncate: 180
        %}
        <div class="story-salon__feature">
          <a class="story-salon__feature-media" href="{{ first_story.url }}">
            {% if first_story.image != blank %}
              {{
                first_story.image
                | image_url: width: 1400
                | image_tag:
                  widths: '500, 800, 1100, 1400',
                  sizes: '(min-width: 990px) 50vw, 100vw',
                  loading: 'lazy',
                  alt: first_story.title
              }}
            {% endif %}

            <div class="story-salon__feature-overlay">
              <span class="story-salon__feature-series">{{ first_series | escape }}</span>
              <strong>{{ first_story.title | escape }}</strong>
            </div>
          </a>

          <div class="story-salon__feature-copy">
            <p class="story-salon__eyebrow">Featured story</p>
            <h3>{{ first_story.title | escape }}</h3>
            <p>{{ first_summary }}</p>
            <a class="story-salon__feature-link" href="{{ first_story.url }}">
              {{ section.settings.explore_label | escape }} <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      {% endif %}

      {% if second_story != blank %}
        {% liquid
          assign second_series = section.settings.first_label
          if second_story.tags contains 'raw'
            assign second_series = section.settings.raw_label
          endif
          assign second_summary = second_story.excerpt_or_content | strip_html | strip_newlines | truncate: 180
        %}
        <div class="story-salon__feature story-salon__feature--flip">
          <a class="story-salon__feature-media" href="{{ second_story.url }}">
            {% if second_story.image != blank %}
              {{
                second_story.image
                | image_url: width: 1400
                | image_tag:
                  widths: '500, 800, 1100, 1400',
                  sizes: '(min-width: 990px) 50vw, 100vw',
                  loading: 'lazy',
                  alt: second_story.title
              }}
            {% endif %}

            <div class="story-salon__feature-overlay">
              <span class="story-salon__feature-series">{{ second_series | escape }}</span>
              <strong>{{ second_story.title | escape }}</strong>
            </div>
          </a>

          <div class="story-salon__feature-copy">
            <p class="story-salon__eyebrow">Next in line</p>
            <h3>{{ second_story.title | escape }}</h3>
            <p>{{ second_summary }}</p>
            <a class="story-salon__feature-link" href="{{ second_story.url }}">
              {{ section.settings.explore_label | escape }} <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      {% endif %}

      {% if story_count > 0 %}
        <div class="story-salon__grid">
          {% for story_article in story_articles %}
            {% liquid
              if story_article.id == first_story.id
                continue
              endif
              if story_article.id == second_story.id
                continue
              endif
              assign card_category = 'first'
              assign card_series = section.settings.first_label
              if story_article.tags contains 'raw'
                assign card_category = 'raw'
                assign card_series = section.settings.raw_label
              endif
              assign card_summary = story_article.excerpt_or_content | strip_html | strip_newlines | truncate: 145
            %}
            <a
              class="story-card"
              data-story-card
              data-category="{{ card_category }}"
              href="{{ story_article.url }}"
            >
              <div class="story-card__media">
                {% if story_article.image != blank %}
                  {{
                    story_article.image
                    | image_url: width: 1000
                    | image_tag:
                      widths: '400, 700, 1000',
                      sizes: '(min-width: 900px) 25vw, 50vw',
                      loading: 'lazy',
                      alt: story_article.title
                  }}
                {% endif %}
                <span class="story-card__series">{{ card_series | escape }}</span>
                <span class="story-card__name">{{ story_article.title | escape }}</span>
              </div>

              <div class="story-card__caption">
                <h3>{{ story_article.title | escape }}</h3>
                <p>{{ card_summary }}</p>
                <span>{{ section.settings.explore_label | escape }} <span aria-hidden="true">→</span></span>
              </div>
            </a>
          {% endfor %}
        </div>
      {% endif %}

      {% assign spotlight_count = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'spotlight' %}
          {% assign spotlight_count = spotlight_count | plus: 1 %}
        {% endif %}
      {% endfor %}

      {% if spotlight_count > 0 %}
        <div class="story-salon__spotlight">
          <header class="story-salon__spotlight-head">
            <span>{{ section.settings.spotlight_heading | escape }}</span>
            <span>{{ section.settings.spotlight_label | escape }}</span>
          </header>

          <div class="story-salon__looks">
            {% for block in section.blocks %}
              {% if block.type == 'spotlight' %}
                <a class="story-look" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
                  <div class="story-look__media">
                    {% if block.settings.image != blank %}
                      {{
                        block.settings.image
                        | image_url: width: 1000
                        | image_tag:
                          widths: '400, 700, 1000',
                          sizes: '(min-width: 900px) 25vw, 50vw',
                          loading: 'lazy',
                          alt: block.settings.person
                      }}
                    {% endif %}
                    <span>{{ block.settings.fabric | escape }}</span>
                  </div>
                  <p>{{ block.settings.series | escape }}</p>
                  <h3>{{ block.settings.person | escape }}</h3>
                  <span>{{ block.settings.product | escape }}</span>
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% javascript %}
  document.querySelectorAll('[data-story-salon]').forEach((section) => {
    const buttons = section.querySelectorAll('[data-story-filter]');
    const cards = section.querySelectorAll('[data-story-card]');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.storyFilter;

        buttons.forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
        cards.forEach((card) => {
          card.hidden = filter !== 'all' && card.dataset.category !== filter;
        });
      });
    });
  });
{% endjavascript %}

{% stylesheet %}
  .story-salon {
    background: var(--salon-paper, #f5f4f1);
    color: var(--salon-ink, #0f1623);
  }

  .story-salon__frame {
    width: min(100%, var(--page-width));
    margin: 0 auto;
    background: var(--salon-paper, #f5f4f1);
  }

  .story-salon__bar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: clamp(0.9rem, 2vw, 1.2rem) var(--page-margin);
    border-bottom: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 56%, transparent);
  }

  .story-salon__mosaic {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    min-height: clamp(24rem, 52vw, 50rem);
    overflow: hidden;
    background: var(--salon-ink, #0f1623);
  }

  .story-salon__tile {
    min-width: 0;
    overflow: hidden;
    position: relative;
  }

  .story-salon__tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.9) contrast(1.05) brightness(0.96);
    transition: transform 700ms cubic-bezier(.2, .7, .2, 1);
  }

  .story-salon__mosaic:hover .story-salon__tile img {
    transform: scale(1.012);
  }

  .story-salon__mosaic::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(to top, rgba(8, 12, 20, 0.78) 0%, rgba(8, 12, 20, 0.12) 44%, transparent 64%),
      linear-gradient(to right, rgba(8, 12, 20, 0.28) 0%, transparent 55%);
  }

  .story-salon__title {
    position: absolute;
    inset: auto var(--page-margin) clamp(1.5rem, 4vw, 4rem) var(--page-margin);
    z-index: 2;
    color: #ffffff;
    max-width: min(42rem, 100%);
    pointer-events: none;
  }

  .story-salon__title p {
    margin: 0;
  }

  .story-salon__title > p:first-child {
    margin-bottom: 0.5rem;
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.62;
  }

  .story-salon__title h1 {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 7vw, 6rem);
    line-height: 0.82;
    letter-spacing: -0.025em;
  }

  .story-salon__lede {
    margin-top: 0.9rem;
    max-width: 34ch;
    font-family: var(--font-body--family);
    font-size: clamp(0.88rem, 1.15vw, 1rem);
    line-height: 1.55;
    color: rgb(255 255 255 / 0.72);
  }

  .story-salon__journal {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .story-salon__intro {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 2rem;
    align-items: end;
    padding: clamp(2.5rem, 6vw, 6rem) var(--page-margin) clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid color-mix(in srgb, currentColor 12%, transparent);
  }

  .story-salon__intro-eyebrow,
  .story-salon__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 1rem;
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 52%, transparent);
  }

  .story-salon__intro-eyebrow::before,
  .story-salon__eyebrow::before {
    content: "";
    width: 1.2rem;
    height: 1px;
    background: color-mix(in srgb, currentColor 38%, transparent);
    flex-shrink: 0;
  }

  .story-salon__intro h2 {
    margin: 0;
    max-width: 24ch;
    font-family: var(--font-heading--family);
    font-size: clamp(1.8rem, 3vw, 3.2rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.025em;
  }

  .story-salon__intro-copy {
    display: grid;
    gap: 1.25rem;
    justify-items: start;
  }

  .story-salon__intro-text {
    max-width: 44rem;
    font-size: 0.95rem;
    line-height: 1.75;
    color: color-mix(in srgb, currentColor 72%, transparent);
  }

  .story-salon__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .story-salon__filters button {
    padding: 0.65rem 1rem;
    border: 1px solid color-mix(in srgb, currentColor 20%, transparent);
    border-radius: 999px;
    color: inherit;
    background: transparent;
    font: inherit;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  .story-salon__filters button[aria-pressed='true'] {
    color: var(--salon-paper, #f5f4f1);
    background: var(--salon-ink, #0f1623);
    border-color: var(--salon-ink, #0f1623);
  }

  .story-salon__feature {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    border-bottom: 1px solid color-mix(in srgb, currentColor 12%, transparent);
  }

  .story-salon__feature--flip {
    direction: rtl;
  }

  .story-salon__feature--flip > * {
    direction: ltr;
  }

  .story-salon__feature-media {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: clamp(28rem, 55vw, 44rem);
    background: #dfe1e3;
    color: inherit;
    text-decoration: none;
  }

  .story-salon__feature-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.1) contrast(1.06) brightness(1.01);
    transform: scale(1.01);
    transition: transform 500ms ease;
  }

  .story-salon__feature:hover img {
    transform: scale(1.03);
  }

  .story-salon__feature-media::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 50% 30%, rgb(255 255 255 / 0.12), transparent 40%),
      linear-gradient(to top, rgb(15 11 8 / 0.62), transparent 60%);
  }

  .story-salon__feature-overlay {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 1;
    padding: clamp(1.2rem, 3vw, 2rem);
    color: #ffffff;
  }

  .story-salon__feature-series {
    display: block;
    margin-bottom: 0.5rem;
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .story-salon__feature-overlay strong {
    display: block;
    font-family: var(--font-heading--family);
    font-size: clamp(1.8rem, 3vw, 3.2rem);
    line-height: 0.94;
    letter-spacing: -0.025em;
    max-width: 12ch;
  }

  .story-salon__feature-overlay p {
    margin: 0.8rem 0 0;
    max-width: 26ch;
    font-size: 0.9rem;
    line-height: 1.55;
    color: rgb(255 255 255 / 0.72);
  }

  .story-salon__feature-copy {
    display: grid;
    align-content: center;
    gap: 1rem;
    padding: clamp(1.5rem, 4vw, 3.5rem);
  }

  .story-salon__feature-copy h3 {
    margin: 0;
    max-width: 12ch;
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 4vw, 4.25rem);
    font-weight: 400;
    line-height: 0.94;
    letter-spacing: -0.03em;
  }

  .story-salon__feature-copy p {
    margin: 0;
    max-width: 38rem;
    font-size: 0.95rem;
    line-height: 1.72;
    color: color-mix(in srgb, currentColor 72%, transparent);
  }

  .story-salon__feature-link {
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    width: fit-content;
    color: var(--salon-accent, #923531);
    text-decoration: none;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .story-salon__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .story-card {
    display: flex;
    min-width: 0;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    border-inline-end: 1px solid color-mix(in srgb, currentColor 14%, transparent);
  }

  .story-card:nth-child(4n) {
    border-inline-end: 0;
  }

  .story-card[hidden] {
    display: none;
  }

  .story-card__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #dfe1e3;
  }

  .story-card__media::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(to top, rgb(15 11 8 / 0.58), transparent 58%),
      radial-gradient(circle at 50% 24%, rgb(255 255 255 / 0.12), transparent 38%);
  }

  .story-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.16) contrast(1.08) brightness(1.02);
    transition: transform 500ms ease;
  }

  .story-card:hover img {
    transform: scale(1.025);
  }

  .story-card__series,
  .story-card__name {
    position: absolute;
    z-index: 1;
    left: 1rem;
    color: #ffffff;
  }

  .story-card__series {
    top: 1rem;
    font-family: var(--font-body--family);
    font-size: 0.58rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .story-card__name {
    bottom: 1rem;
    max-width: 12ch;
    font-family: var(--font-heading--family);
    font-size: clamp(1.2rem, 2vw, 2rem);
    line-height: 0.95;
    letter-spacing: -0.025em;
  }

  .story-card__caption {
    padding: 1rem 1rem 1.75rem;
  }

  .story-card__caption h3 {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .story-card__caption p {
    min-height: 4.5em;
    margin: 0.55rem 0 0;
    font-size: 0.78rem;
    line-height: 1.5;
    color: color-mix(in srgb, currentColor 70%, transparent);
  }

  .story-card__caption > span {
    display: inline-block;
    margin-top: 0.8rem;
    color: var(--salon-accent, #923531);
    font-family: var(--font-body--family);
    font-size: 0.64rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .story-salon__spotlight {
    padding: clamp(3rem, 7vw, 7rem) var(--page-margin);
    border-top: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    background: var(--salon-ink, #0f1623);
    color: #ffffff;
  }

  .story-salon__spotlight-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-body--family);
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .story-salon__looks {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin-top: 1.5rem;
  }

  .story-look {
    background: var(--salon-ink, #0f1623);
    color: inherit;
    text-decoration: none;
    padding: clamp(1rem, 2.5vw, 1.5rem);
  }

  .story-look__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.05);
    margin-bottom: 0.9rem;
  }

  .story-look__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms ease;
  }

  .story-look:hover img {
    transform: scale(1.025);
  }

  .story-look__media span {
    position: absolute;
    inset: 0.8rem auto auto 0.8rem;
    padding: 0.35rem 0.5rem;
    color: #ffffff;
    background: rgba(15, 22, 35, 0.82);
    font-family: var(--font-body--family);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .story-look > p {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
  }

  .story-look h3 {
    margin: 0.35rem 0;
    font-family: var(--font-heading--family);
    font-size: 1.15rem;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.025em;
  }

  .story-look > span {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.68);
  }

  @media screen and (max-width: 989px) {
    .story-salon__intro,
    .story-salon__feature {
      grid-template-columns: 1fr;
    }

    .story-salon__feature--flip {
      direction: ltr;
    }

    .story-salon__looks,
    .story-salon__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .story-card:nth-child(4n) {
      border-inline-end: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    }

    .story-card:nth-child(2n) {
      border-inline-end: 0;
    }
  }

  @media screen and (max-width: 749px) {
    .story-salon__bar {
      font-size: 0.58rem;
      letter-spacing: 0.16em;
    }

    .story-salon__mosaic {
      grid-template-columns: repeat(2, 1fr);
      min-height: 34rem;
    }

    .story-salon__tile:last-of-type {
      display: none;
    }

    .story-salon__title {
      inset-inline: 1rem;
    }

    .story-salon__title h1 {
      font-size: clamp(2rem, 15vw, 4.5rem);
    }

    .story-salon__intro,
    .story-salon__feature-copy,
    .story-salon__spotlight {
      padding-inline: 1rem;
    }

    .story-salon__grid,
    .story-salon__looks {
      grid-template-columns: 1fr;
    }

    .story-card {
      border-inline-end: 0;
      border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    }

    .story-card:last-child {
      border-bottom: 0;
    }
  }
{% endstylesheet %}

