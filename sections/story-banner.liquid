{%- style -%}
  .section-{{ section.id }} {
    --outer: clamp(20px, 4vw, 56px);
    --max: 1440px;
    background: #0f1623;
  }
  .banner { position: relative; width: 100%; }
  .banner__media {
    position: relative; overflow: hidden;
    min-height: clamp(260px, 44vh, 480px);
    display: flex; align-items: flex-end;
    background: #1a1d20;
  }
  .banner__media img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  }
  .banner__scrim {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(15,11,8,.8) 0%, rgba(15,11,8,.3) 50%, rgba(15,11,8,.12) 100%);
    pointer-events: none;
  }
  .banner__inner {
    position: relative;
    padding: clamp(22px, 4vw, 56px) var(--outer);
    color: #f6f2ea; max-width: var(--max); margin: 0 auto; width: 100%;
    z-index: 2;
  }
  .banner__crumbs {
    display: flex; gap: 8px; align-items: center;
    font-family: "Archivo", system-ui, sans-serif;
    font-size: 11px; font-weight: 500; letter-spacing: .18em; text-transform: uppercase;
    color: rgba(246,242,234,.72); margin-bottom: 12px;
  }
  .banner__crumbs a:hover { color: #f0c3b6; }
  .banner .eyebrow {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
    color: #e9b9ac; display: inline-flex; align-items: center; gap: 12px;
  }
  .banner .eyebrow::before { content: ""; width: 26px; height: 1px; background: #e9b9ac; }
  .banner h1 {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-weight: 400; font-size: clamp(45px, 8vw, 94px); line-height: .9;
    margin: 12px 0 0; text-wrap: balance; color: #f6f2ea; letter-spacing: -0.025em;
  }
  .banner h1 i, .banner h1 em { color: #f0c3b6; font-style: italic; }
  .banner__lede {
    margin: 14px 0 0;
    font-family: "DM Sans", system-ui, sans-serif;
    font-size: 14px; letter-spacing: -0.025em; line-height: 1.5;
    color: rgba(246,242,234,.86); max-width: 52ch; text-wrap: pretty;
  }
{%- endstyle -%}

<section class="section-{{ section.id }} banner" aria-label="{{ section.settings.title | escape }}">
  <div class="banner__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', sizes: '100vw' }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}

    <div class="banner__scrim"></div>

    <div class="banner__inner">
      {%- if section.settings.show_breadcrumbs -%}
        <div class="banner__crumbs">
          <a href="{{ routes.root_url }}">TRIIIPLE</a><span>/</span><span style="color:#f6f2ea;">{{ page.title | default: 'Story Salon' }}</span>
        </div>
      {%- endif -%}
      
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      
      {%- if section.settings.title != blank -%}
        <h1>{{ section.settings.title }}</h1>
      {%- endif -%}
      
      {%- if section.settings.lede != blank -%}
        <p class="banner__lede">{{ section.settings.lede }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Story Banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background Image" },
    { "type": "checkbox", "id": "show_breadcrumbs", "label": "Show Breadcrumbs", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The TRIIIPLE Journal" },
    { "type": "html", "id": "title", "label": "Title", "default": "Story <i>Salon</i>", "info": "Use <i> tags to italicize and color words." },
    { "type": "textarea", "id": "lede", "label": "Lede Text", "default": "Conversations and portraits from the studio — connected by one idea: confidence that starts from the first layer up." }
  ],
  "presets": [{ "name": "Story Banner" }]
}
{% endschema %}