<style>
  .triiiple-shop-strip { padding: clamp(60px, 10vw, 120px) {{ section.settings.side_margin }}px; background: var(--paper); color: var(--ink); }
  .shop-header { padding: 0 var(--gut); display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; }
  .rail { display: flex; gap: 16px; padding: 0 var(--gut); overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; }
  .rail::-webkit-scrollbar { display: none; }
  .product-card { flex: 0 0 {{ section.settings.card_size }}; scroll-snap-align: start; text-decoration: none; color: inherit; }
  .card-img { aspect-ratio: 4/5; background: var(--paper-2); border-radius: 20px; overflow: hidden; margin-bottom: 16px; position: relative; }
  .card-img img { width: 100%; height: 100%; object-fit: cover; }
  .product-meta { display: flex; justify-content: space-between; font-family: var(--font-body); font-size: 14px; }
  .product-price { color: var(--muted); }
  @media (max-width: 1024px) { .product-card { flex: 0 0 calc(40% - 12px); } }
  @media (max-width: 640px) { .product-card { flex: 0 0 {{ section.settings.card_size_mobile }}; } .card-img { border-radius: 14px; } }
</style>

<section class="triiiple-shop-strip">
  <div class="shop-header triiiple-reveal">
    <h2 class="triiiple-heading text-large">{{ section.settings.title }}</h2>
    {% if section.settings.collection != blank %}
      <a href="{{ section.settings.collection.url }}" class="triiiple-link" style="margin:0;">View all <span>→</span></a>
    {% endif %}
  </div>
  
  <div class="rail triiiple-reveal stagger-1">
    {% for product in section.settings.collection.products limit: section.settings.limit %}
      <a href="{{ product.url }}" class="product-card">
        <div class="card-img">
          {% if product.featured_image %}
            {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag }}
          {% endif %}
        </div>
        <div class="product-meta">
          <span>{{ product.title }}</span>
          <span class="product-price">{{ product.price | money_without_trailing_zeros }}</span>
        </div>
      </a>
    {% else %}
      <!-- Fallback if no collection selected -->
      {% for i in (1..4) %}
        <div class="product-card">
          <div class="card-img">{{ 'product-' | append: i | placeholder_svg_tag }}</div>
          <div class="product-meta"><span>Example Product</span><span class="product-price">$180</span></div>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Shop Strip",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "What are you looking for?"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "side_margin",
      "label": "Side margin (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 20
    },
    {
      "type": "select",
      "id": "card_size",
      "label": "Card size",
      "options": [
        { "value": "calc(20% - 12px)", "label": "XS — 5 visible" },
        { "value": "calc(25% - 12px)", "label": "S — 4 visible" },
        { "value": "calc(33% - 12px)", "label": "M — 3 visible" },
        { "value": "calc(45% - 12px)", "label": "L — 2.2 visible" }
      ],
      "default": "calc(25% - 12px)"
    },
    {
      "type": "select",
      "id": "card_size_mobile",
      "label": "Card size (mobile)",
      "options": [
        { "value": "calc(60% - 12px)", "label": "S — 1.6 visible" },
        { "value": "calc(75% - 12px)", "label": "M — 1.3 visible" },
        { "value": "calc(88% - 12px)", "label": "L — 1.1 visible" }
      ],
      "default": "calc(75% - 12px)"
    }
  ],
  "presets": [{ "name": "Shop Strip" }]
}
{% endschema %}