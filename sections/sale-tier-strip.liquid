{%- liquid
  assign bg = section.settings.bg_color
  assign border_top_color = section.settings.border_top_color
  assign accent = section.settings.accent_color
  assign text = section.settings.text_color
  assign muted = section.settings.muted_color
  assign highlight_size = section.settings.highlight_size
-%}

<div class="sts" style="--sts-bg:{{ bg }};--sts-btc:{{ border_top_color }};--sts-accent:{{ accent }};--sts-text:{{ text }};--sts-muted:{{ muted }};--sts-hs:{{ highlight_size }}px;">
  <div class="sts__items">
    {%- for block in section.blocks -%}
      <div class="sts__item" {{ block.shopify_attributes }}>
        <span class="sts__pct" style="font-weight:{{ block.settings.highlight_weight }};">{{ block.settings.highlight }}</span>
        <span class="sts__label">{{ block.settings.label }}</span>
      </div>
    {%- endfor -%}
    {%- if section.settings.badge_text != blank -%}
      <div class="sts__badge">{{ section.settings.badge_text }}</div>
    {%- endif -%}
  </div>
</div>

<style>
  .sts {
    background: var(--sts-bg);
    border-top: 2px solid var(--sts-btc);
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sts__items {
    display: flex;
    align-items: center;
    width: 100%;
    overflow-x: auto;
  }

  .sts__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 40px;
    font-family: monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sts-text);
    border-right: 1px solid rgba(0, 0, 0, 0.08);
    flex-shrink: 0;
  }

  .sts__item:last-of-type {
    border-right: none;
  }

  .sts__pct {
    font-size: var(--sts-hs, 20px);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--sts-accent);
    display: inline-block;
    min-width: 1.2em;
    text-align: center;
    font-weight: inherit;
  }

  .sts__label {
    white-space: nowrap;
  }

  .sts__badge {
    padding: 0 40px;
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sts-muted);
    border-left: 1px solid rgba(0, 0, 0, 0.08);
    margin-left: auto;
    flex-shrink: 0;
  }

  @media (max-width: 749px) {
    .sts {
      height: auto;
      padding: 12px 16px;
    }

    .sts__items {
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      overflow-x: visible;
    }

    .sts__item {
      padding: 6px 16px;
      border-right: none;
      font-size: 9px;
      flex-shrink: 1;
    }

    .sts__pct {
      font-size: calc(var(--sts-hs, 20px) * 0.8);
    }

    .sts__badge {
      border-left: none;
      padding: 6px 16px;
      margin-left: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Sale Tier Strip",
  "tag": "section",
  "class": "sale-tier-strip-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#E7E3DC"
    },
    {
      "type": "color",
      "id": "border_top_color",
      "label": "Top border",
      "default": "#923531"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Highlight color",
      "default": "#923531"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#212529"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Badge color",
      "default": "rgba(33,37,41,0.42)"
    },
    {
      "type": "range",
      "id": "highlight_size",
      "label": "Highlight number size (px) — uniform across all tiers",
      "min": 14,
      "max": 40,
      "step": 1,
      "default": 20
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "No code needed"
    }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Tier",
      "settings": [
        {
          "type": "text",
          "id": "highlight",
          "label": "Highlight",
          "default": "15%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "off — 3 items"
        },
        {
          "type": "select",
          "id": "highlight_weight",
          "label": "Highlight weight",
          "options": [
            {
              "value": "300",
              "label": "Light (300)"
            },
            {
              "value": "400",
              "label": "Regular (400)"
            },
            {
              "value": "500",
              "label": "Medium (500)"
            },
            {
              "value": "600",
              "label": "Semibold (600)"
            },
            {
              "value": "700",
              "label": "Bold (700)"
            },
            {
              "value": "800",
              "label": "Extra bold (800)"
            }
          ],
          "default": "400"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sale Tier Strip",
      "blocks": [
        {
          "type": "tier",
          "settings": {
            "highlight": "15%",
            "label": "off — 3 items"
          }
        },
        {
          "type": "tier",
          "settings": {
            "highlight": "25%",
            "label": "off — 5 items"
          }
        },
        {
          "type": "tier",
          "settings": {
            "highlight": "$50+",
            "label": "free shipping · SG"
          }
        }
      ]
    }
  ]
}
{% endschema %}
