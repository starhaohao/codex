{%- style -%}
  .section-{{ section.id }} {
    --outer: clamp(20px, 4vw, 56px); --max: 1440px; --t: 360ms cubic-bezier(.2,.7,.2,1);
    background: #EEEEEA; color: #212529; padding: clamp(8px, 1.5vw, 20px) 0 clamp(48px, 7vw, 96px); border-top: 1px solid rgba(33,37,41,.12);
  }
  .section-{{ section.id }} .wrap { max-width: var(--max); margin: 0 auto; padding: 0 var(--outer); }
  
  .series-rule {
    display: flex; align-items: baseline; justify-content: space-between; gap: 20px;
    padding: clamp(52px, 8vw, 104px) 0 clamp(20px, 3vw, 30px); border-bottom: 1px solid rgba(33,37,41,.16);
  }
  .series-rule__id { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 11px; letter-spacing: .2em; text-transform: uppercase; color: #923531; }
  .series-rule__count { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: rgba(33,37,41,.55); white-space: nowrap; }

  .lookbook { padding: clamp(28px, 4vw, 48px) 0 0; }
  .lookbook__cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: clamp(12px, 2vw, 24px); }
  @media (min-width: 760px)  { .lookbook__cards { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1100px) { .lookbook__cards { grid-template-columns: repeat(4, 1fr); } }

  .look { display: block; text-decoration: none; color: inherit; }
  .look__media {
    position: relative; overflow: hidden; border-radius: 0px; aspect-ratio: 4/5; transition: transform var(--t); background: #dcdcd6;
  }
  @media (max-width: 749px) { .look__media { border-radius: 0px; } }
  .look:hover .look__media { transform: translateY(-3px); }
  .look__media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  
  .look__media .num {
    position: absolute; top: 12px; left: 12px; z-index: 2; font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 10px; letter-spacing: .14em;
    color: rgba(246,242,234,.92); background: rgba(0,0,0,.28); padding: 5px 9px; border-radius: 999px; backdrop-filter: blur(2px);
  }
  .look__meta { margin-top: 12px; font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 10.5px; letter-spacing: .14em; text-transform: uppercase; color: rgba(33,37,41,.55); }
  .look__name { font-family: "Galdeano", serif; font-size: clamp(18px, 1.6vw, 21px); font-weight: 400; letter-spacing: -0.01em; margin: 6px 0 2px; line-height: 1.12; }
  .look__wear { font-family: "DM Sans", sans-serif; margin: 0; font-size: 13px; color: rgba(33,37,41,.76); line-height: 1.45; }
{%- endstyle -%}

<section class="section-{{ section.id }}">
  <div class="wrap">
    <div class="series-rule">
      <span class="series-rule__id">{{ section.settings.title }}</span>
      <span class="series-rule__count">{{ section.settings.subtitle }}</span>
    </div>

    <div class="lookbook">
      <div class="lookbook__cards">
        {%- for block in section.blocks -%}
          <a class="look" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
            <div class="look__media">
              <span class="num">{{ block.settings.number }}</span>
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <p class="look__meta">{{ block.settings.meta }}</p>
            <h3 class="look__name">{{ block.settings.subject_name }}</h3>
            <p class="look__wear">{{ block.settings.wear_text }}</p>
          </a>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lookbook Gallery",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Lookbook — What They Wear" },
    { "type": "text", "id": "subtitle", "label": "Subheading", "default": "From the cast" }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look Card",
      "settings": [
        { "type": "text", "id": "number", "label": "Badge Number", "default": "No. 01" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "meta", "label": "Series Meta", "default": "The First Layer" },
        { "type": "text", "id": "subject_name", "label": "Subject Name", "default": "Ethan Cheng" },
        { "type": "text", "id": "wear_text", "label": "As Worn Text", "default": "The V — Cotton Spandex Brief, Sand" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Lookbook Gallery" }]
}
{% endschema %}