{% liquid
  assign article_excerpt = article.excerpt_or_content | strip_html | strip_newlines | truncate: 220
  assign related_count = 0
  assign share_url = request.origin | append: article.url
  assign wear_collection = section.settings.related_products_collection
%}

<article
  class="story-salon-article"
  data-story-salon-article
  style="
    --salon-ink: {{ section.settings.ink }};
    --salon-paper: {{ section.settings.paper }};
    --salon-accent: {{ section.settings.accent }};
  "
>
  <header class="story-salon-article__hero">
    <div class="story-salon-article__bar">
      <a href="/pages/story-salon" class="story-salon-article__back">
        <span aria-hidden="true">←</span> {{ section.settings.back_label | escape }}
      </a>
      <span>{{ article.published_at | date: '%d %b %Y' }}</span>
    </div>

    <div class="story-salon-article__hero-grid">
      <div class="story-salon-article__media">
        {% if article.image != blank %}
          {{
            article.image
            | image_url: width: 1800
            | image_tag:
              widths: '700, 1000, 1400, 1800',
              sizes: '(min-width: 990px) 52vw, 100vw',
              loading: 'eager',
              alt: article.title
          }}
        {% else %}
          <div class="story-salon-article__placeholder"></div>
        {% endif %}
      </div>

      <div class="story-salon-article__copy">
        <p class="story-salon-article__eyebrow">
          {{ section.settings.hero_eyebrow | escape }}
        </p>
        <h1 class="story-salon-article__title-handwritten">{{ article.title | escape }}</h1>

        {% if article.tags != blank %}
          <div class="story-salon-article__tags" aria-label="Story tags">
            {% for tag in article.tags %}
              <span>{{ tag | escape }}</span>
            {% endfor %}
          </div>
        {% endif %}

        {% if article_excerpt != blank %}
          <p class="story-salon-article__lede">{{ article_excerpt }}</p>
        {% endif %}

        <div class="story-salon-article__share" data-story-share>
          <div class="story-salon-article__share-head">
            <p class="story-salon-article__share-label">{{ section.settings.share_label | escape }}</p>
            <button
              type="button"
              class="story-salon-article__share-button"
              data-story-share-button
              data-share-title="{{ article.title | escape }}"
              data-share-url="{{ share_url | escape }}"
            >
              {{ section.settings.share_button_label | escape }}
            </button>
          </div>

          <div class="story-salon-article__share-links" aria-label="Social media share links">
            <a
              class="story-salon-article__share-link"
              href="https://www.facebook.com/sharer/sharer.php?u={{ share_url | url_encode }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Share on Facebook"
            >
              {% render 'icon', icon: 'facebook' %}
              <span>Facebook</span>
            </a>
            <a
              class="story-salon-article__share-link"
              href="https://www.pinterest.com/pin/create/button/?url={{ share_url | url_encode }}&description={{ article.title | url_encode }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Share on Pinterest"
            >
              {% render 'icon', icon: 'pinterest' %}
              <span>Pinterest</span>
            </a>
            <a
              class="story-salon-article__share-link"
              href="https://wa.me/?text={{ article.title | append: ' ' | append: share_url | url_encode }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Share on WhatsApp"
            >
              {% render 'icon', icon: 'whatsapp' %}
              <span>WhatsApp</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </header>

  <div class="story-salon-article__body">
    <div class="story-salon-article__content">
      {% if article.content != blank %}
        <div class="story-salon-article__richtext rte story-salon-article__flow">
          {{ article.content }}
        </div>
      {% endif %}
    </div>

    <aside class="story-salon-article__aside">
      <div class="story-salon-article__note">
        <p class="story-salon-article__note-label">About this story</p>
        <p>
          {{ section.settings.aside_text | escape }}
        </p>
      </div>

      {% if blog.articles != blank %}
        <div class="story-salon-article__rail">
          <p class="story-salon-article__rail-label">{{ section.settings.related_label | escape }}</p>

          {% for related in blog.articles %}
            {% if related.id != article.id and related_count < 4 %}
              {% assign related_count = related_count | plus: 1 %}
              <a class="story-salon-article__related" href="{{ related.url }}">
                {% if related.image != blank %}
                  {{
                    related.image
                    | image_url: width: 600
                    | image_tag:
                      widths: '320, 500, 700',
                      sizes: '(min-width: 990px) 20vw, 50vw',
                      loading: 'lazy',
                      alt: related.title
                  }}
                {% endif %}
                <div>
                  <p>{{ related.title | escape }}</p>
                  <span>{{ related.published_at | date: '%d %b %Y' }}</span>
                </div>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </aside>
  </div>

  {% if wear_collection != blank and wear_collection.products_count > 0 %}
    <section class="story-salon-article__wear">
      <div class="story-salon-article__wear-head">
        <div>
          <p class="story-salon-article__wear-label">{{ section.settings.wear_eyebrow | escape }}</p>
          <h2 class="story-salon-article__wear-title">{{ section.settings.wear_heading | escape }}</h2>
        </div>
        {% if section.settings.wear_link != blank %}
          <a class="story-salon-article__wear-link" href="{{ section.settings.wear_link }}">
            {{ section.settings.wear_link_label | escape }}
            <span aria-hidden="true">→</span>
          </a>
        {% endif %}
      </div>

      <div class="story-salon-article__wear-grid">
        {% for product in wear_collection.products limit: 4 %}
          {% liquid
            assign wear_block_id = 'story-salon-article-product-' | append: product.id
          %}
          <div class="story-salon-article__wear-card">
            {% content_for 'block',
              type: '_product-card',
              id: wear_block_id,
              closest.product: product,
              product_view_context: 'article'
            %}
          </div>
        {% endfor %}
      </div>
    </section>
  {% endif %}
</article>

{% javascript %}
  document.querySelectorAll('[data-story-share]').forEach((share) => {
    const button = share.querySelector('[data-story-share-button]');

    if (!button) return;

    button.addEventListener('click', async () => {
      const shareTitle = button.dataset.shareTitle || document.title;
      const shareUrl = button.dataset.shareUrl || window.location.href;

      try {
        if (navigator.share) {
          await navigator.share({
            title: shareTitle,
            url: shareUrl,
          });
          return;
        }

        await navigator.clipboard.writeText(shareUrl);
        const label = button.textContent;
        button.textContent = 'Link copied';
        window.setTimeout(() => {
          button.textContent = label;
        }, 1800);
      } catch (error) {
        window.open(shareUrl, '_blank', 'noopener,noreferrer');
      }
    });
  });
{% endjavascript %}

{% stylesheet %}
  @import url('https://fonts.googleapis.com/css2?family=Nothing+You+Could+Do&display=swap');

  .story-salon-article {
    background: var(--salon-paper, #f5f4f1);
    color: var(--salon-ink, #0f1623);
  }

  .story-salon-article__hero {
    background: var(--salon-ink, #0f1623);
    color: #ffffff;
  }

  .story-salon-article__bar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: clamp(0.9rem, 2vw, 1.2rem) var(--page-margin);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
  }

  .story-salon-article__back {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .story-salon-article__hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    min-height: clamp(42rem, 80svh, 54rem);
  }

  .story-salon-article__media {
    position: relative;
    overflow: hidden;
    background: #111827;
  }

  .story-salon-article__media img,
  .story-salon-article__placeholder {
    width: 100%;
    height: 100%;
  }

  .story-salon-article__media img {
    object-fit: cover;
    filter: saturate(1.08) contrast(1.06) brightness(1.01);
  }

  .story-salon-article__placeholder {
    background:
      repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.04) 0 2px, transparent 2px 11px),
      linear-gradient(160deg, #1e2840, #0a0f1a);
  }

  .story-salon-article__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(8, 12, 20, 0.78) 0%, rgba(8, 12, 20, 0.1) 45%, transparent 66%),
      linear-gradient(to right, rgba(8, 12, 20, 0.18) 0%, transparent 52%);
    pointer-events: none;
  }

  .story-salon-article__copy {
    display: grid;
    align-content: end;
    gap: 1rem;
    padding: clamp(1.5rem, 4vw, 3rem);
    border-left: 1px solid rgba(255, 255, 255, 0.12);
  }

  .story-salon-article__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
  }

  .story-salon-article__eyebrow::before {
    content: "";
    width: 1.2rem;
    height: 1px;
    background: rgba(255, 255, 255, 0.36);
    flex-shrink: 0;
  }

  .story-salon-article__copy h1 {
    margin: 0;
    max-width: 10ch;
    font-family: "Nothing You Could Do", "Galdeano", cursive;
    font-size: clamp(2.5rem, 5vw, 5.8rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
  }

  .story-salon-article__title-handwritten {
    text-wrap: balance;
  }

  .story-salon-article__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .story-salon-article__tags span {
    padding: 0.45rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    font-family: var(--font-body--family);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }

  .story-salon-article__lede {
    margin: 0;
    max-width: 34ch;
    font-size: clamp(0.98rem, 1.2vw, 1.12rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.76);
  }

  .story-salon-article__deck {
    max-width: 38rem;
    font-size: 0.95rem;
    line-height: 1.72;
    color: rgba(255, 255, 255, 0.68);
  }

  .story-salon-article__share {
    display: grid;
    gap: 1rem;
    padding-top: 0.25rem;
  }

  .story-salon-article__share-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .story-salon-article__share-label {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
  }

  .story-salon-article__share-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    color: #ffffff;
    font-family: var(--font-body--family);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 180ms ease, border-color 180ms ease, transform 180ms ease;
  }

  .story-salon-article__share-button:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.24);
    transform: translateY(-1px);
  }

  .story-salon-article__share-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .story-salon-article__share-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.72rem 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  .story-salon-article__share-link:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    color: #ffffff;
  }

  .story-salon-article__share-link svg {
    width: 0.95rem;
    height: 0.95rem;
  }

  .story-salon-article__share-link span {
    font-family: var(--font-body--family);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .story-salon-article__body {
    display: block;
  }

  .story-salon-article__content {
    padding: 0;
  }

  .story-salon-article__richtext {
    max-width: none;
    margin: 0;
    font-size: 1rem;
    line-height: 1.85;
  }

  .story-salon-article__flow {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .story-salon-article__flow > :is(h2, h3) {
    max-width: 18ch;
    margin: clamp(1rem, 2vw, 1.5rem) 0 0;
    font-family: "Nothing You Could Do", "Galdeano", cursive;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .story-salon-article__flow > p {
    max-width: 42rem;
    margin: 0;
  }

  .story-salon-article__flow > blockquote {
    max-width: 28rem;
    margin: clamp(1.25rem, 2.5vw, 2rem) 0;
    padding: 1rem 0 1rem 1.1rem;
    border-left: 1px solid color-mix(in srgb, currentColor 20%, transparent);
    font-family: "Nothing You Could Do", "Galdeano", cursive;
    font-size: clamp(1.4rem, 2.4vw, 2.6rem);
    line-height: 1.16;
    letter-spacing: -0.02em;
    font-style: normal;
  }

  .story-salon-article__flow > figure,
  .story-salon-article__flow > img {
    width: 100%;
    margin: clamp(1rem, 3vw, 2rem) 0;
  }

  .story-salon-article__flow > figure img,
  .story-salon-article__flow > img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: 0;
  }

  .story-salon-article__flow > figure figcaption {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.65rem;
    border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 54%, transparent);
  }

  .story-editorial__intro {
    max-width: 54rem;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 7rem) var(--page-margin);
  }

  .story-editorial__intro :is(h2, h3),
  .story-editorial__panel-copy :is(h2, h3) {
    margin: 0;
    font-family: var(--font-heading--family);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.08;
  }

  .story-editorial__intro h2 {
    font-size: clamp(2rem, 4vw, 4.5rem);
  }

  .story-editorial__intro p {
    max-width: 48rem;
    margin: 1.2rem 0 0;
    color: color-mix(in srgb, currentColor 72%, transparent);
  }

  .story-editorial__intro p + p {
    margin-top: 1rem;
  }

  .story-editorial__wide,
  .story-editorial__portrait,
  .story-editorial__gallery figure {
    margin: 0;
    overflow: hidden;
    background: #dfe1e3;
  }

  .story-editorial__wide img,
  .story-editorial__portrait img,
  .story-editorial__gallery img {
    display: block;
    width: 100%;
    margin: 0;
    object-fit: cover;
  }

  .story-editorial__wide img {
    aspect-ratio: 16 / 9;
  }

  .story-editorial__caption,
  .story-editorial__gallery figcaption {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem var(--page-margin);
    border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    line-height: 1.4;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 54%, transparent);
  }

  .story-editorial__split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    min-height: 38rem;
    border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
  }

  .story-editorial__split--reverse .story-editorial__portrait {
    order: 2;
  }

  .story-editorial__portrait img {
    height: 100%;
    min-height: 38rem;
  }

  .story-editorial__panel-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2rem, 6vw, 6rem) var(--page-margin);
  }

  .story-editorial__kicker {
    margin: 0 0 1rem;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    line-height: 1.4;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 54%, transparent);
  }

  .story-editorial__panel-copy h3 {
    max-width: 24ch;
    font-size: clamp(1.8rem, 3vw, 3.3rem);
  }

  .story-editorial__panel-copy p:last-child {
    max-width: 42rem;
    margin: 1.2rem 0 0;
    color: color-mix(in srgb, currentColor 72%, transparent);
  }

  .story-editorial__quote {
    margin: 0;
    padding: clamp(3.5rem, 8vw, 8rem) var(--page-margin);
    border-block: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    background: color-mix(in srgb, var(--salon-paper, #f5f4f1) 86%, white);
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 4vw, 4rem);
    font-style: normal;
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.08;
  }

  .story-editorial__quote p {
    max-width: 22ch;
    margin: 0;
  }

  .story-editorial__quote cite {
    display: block;
    margin-top: 1.4rem;
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    font-style: normal;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 54%, transparent);
  }

  .story-editorial__gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
  }

  .story-editorial__gallery figure {
    border-right: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    border-bottom: 1px solid color-mix(in srgb, currentColor 12%, transparent);
  }

  .story-editorial__gallery figure:nth-child(2n) {
    border-right: 0;
  }

  .story-editorial__gallery img {
    aspect-ratio: 4 / 3;
  }

  .story-salon-article__aside {
    display: grid;
    grid-template-columns: minmax(0, 0.65fr) minmax(0, 1.35fr);
    gap: clamp(2rem, 6vw, 6rem);
    max-width: var(--page-width);
    margin: 0 auto;
    border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    background: color-mix(in srgb, var(--salon-paper, #f5f4f1) 84%, white);
    padding: clamp(2rem, 5vw, 4rem) var(--page-margin);
    align-content: start;
  }

  .story-salon-article__note {
    display: grid;
    gap: 0.75rem;
  }

  .story-salon-article__note-label,
  .story-salon-article__rail-label {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 54%, transparent);
  }

  .story-salon-article__note p:last-child {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.75;
    color: color-mix(in srgb, currentColor 74%, transparent);
  }

  .story-salon-article__rail {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .story-salon-article__rail-label {
    grid-column: 1 / -1;
  }

  .story-salon-article__related {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    gap: 0.85rem;
    align-items: center;
    color: inherit;
    text-decoration: none;
    padding-top: 0.9rem;
    border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
  }

  .story-salon-article__related img {
    width: 96px;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    background: #dfe1e3;
  }

  .story-salon-article__related p {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: 1.05rem;
    line-height: 1.1;
    letter-spacing: -0.025em;
  }

  .story-salon-article__related span {
    display: block;
    margin-top: 0.35rem;
    font-family: var(--font-body--family);
    font-size: 0.56rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 52%, transparent);
  }

  .story-salon-article__wear {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 6rem) var(--page-margin);
    border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    background: color-mix(in srgb, var(--salon-paper, #f5f4f1) 88%, white);
  }

  .story-salon-article__wear-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .story-salon-article__wear-label {
    margin: 0 0 0.5rem;
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 54%, transparent);
  }

  .story-salon-article__wear-title {
    margin: 0;
    font-family: "Nothing You Could Do", "Galdeano", cursive;
    font-size: clamp(1.8rem, 3vw, 3.4rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .story-salon-article__wear-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--salon-accent, #923531);
    font-family: var(--font-body--family);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
  }

  .story-salon-article__wear-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    background: color-mix(in srgb, currentColor 12%, transparent);
  }

  .story-salon-article__wear-card {
    min-width: 0;
    background: var(--salon-paper, #f5f4f1);
  }

  @media screen and (max-width: 989px) {
    .story-salon-article__hero-grid {
      grid-template-columns: 1fr;
    }

    .story-salon-article__copy {
      border-left: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
      min-height: auto;
    }

    .story-salon-article__aside {
      grid-template-columns: 1fr;
    }

    .story-salon-article__wear-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .story-salon-article__bar {
      font-size: 0.58rem;
      letter-spacing: 0.16em;
    }

    .story-salon-article__hero-grid {
      min-height: auto;
    }

    .story-salon-article__media {
      min-height: 28rem;
    }

    .story-salon-article__copy,
    .story-salon-article__aside {
      padding-inline: 1rem;
    }

    .story-salon-article__copy h1 {
      max-width: 12ch;
      font-size: clamp(2.3rem, 14vw, 4.5rem);
    }

    .story-editorial__intro,
    .story-editorial__panel-copy,
    .story-editorial__quote {
      padding-inline: 1rem;
    }

    .story-editorial__split {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .story-editorial__split--reverse .story-editorial__portrait {
      order: 0;
    }

    .story-editorial__portrait img {
      min-height: auto;
      aspect-ratio: 4 / 5;
    }

    .story-editorial__wide img {
      aspect-ratio: 4 / 5;
    }

    .story-editorial__gallery {
      grid-template-columns: 1fr;
    }

    .story-editorial__gallery figure,
    .story-editorial__gallery figure:nth-child(2n) {
      border-right: 0;
    }

    .story-salon-article__rail {
      grid-template-columns: 1fr;
    }

    .story-salon-article__wear-head {
      flex-direction: column;
      align-items: start;
    }

    .story-salon-article__wear-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

