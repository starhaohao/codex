{% liquid
  assign story_articles = blog.articles
  assign hero_articles = story_articles | slice: 0, 5
%}

<section
  class="story-salon-blog"
  data-story-salon-blog
  style="
    --story-paper: {{ section.settings.paper }};
    --story-ink: {{ section.settings.ink }};
    --story-accent: {{ section.settings.accent }};
  "
>
  <div class="story-salon-blog__hero">
    <div class="story-salon-blog__bar">
      <span>TRIIIPLE Studio</span>
      <span>Story Salon / {{ story_articles.size }} stories</span>
    </div>

    <div class="story-salon-blog__mosaic">
      {% for article in hero_articles %}
        <div class="story-salon-blog__tile story-salon-blog__tile--{{ forloop.index }}">
          {% if article.image != blank %}
            {{
              article.image
              | image_url: width: 1200
              | image_tag:
                widths: '400, 700, 1000, 1200',
                sizes: '(min-width: 750px) 20vw, 50vw',
                loading: 'eager',
                alt: article.title
            }}
          {% endif %}
        </div>
      {% endfor %}

      <div class="story-salon-blog__title">
        <p>{{ section.settings.hero_eyebrow | escape }}</p>
        <h1>{{ section.settings.hero_title | escape }}</h1>
        <p class="story-salon-blog__lede">{{ section.settings.hero_lede }}</p>
        <a class="story-salon-blog__cta" href="#story-salon-archive">
          {{ section.settings.cta_label | escape }}
        </a>
      </div>
    </div>
  </div>

  <div class="story-salon-blog__journal" id="story-salon-archive">
    <header class="story-salon-blog__intro">
      <div class="story-salon-blog__intro-heading">
        <p class="story-salon-blog__intro-eyebrow">Editorial room</p>
        <h2>{{ section.settings.intro_heading | newline_to_br }}</h2>
      </div>

      <div class="story-salon-blog__intro-copy">
        {% if section.settings.intro_text != blank %}
          <div class="story-salon-blog__intro-text rte">{{ section.settings.intro_text }}</div>
        {% endif %}

        <div class="story-salon-blog__filters" aria-label="Story filters">
          <button type="button" aria-pressed="true" data-story-filter="all">
            {{ section.settings.all_label | escape }}
          </button>
          <button type="button" aria-pressed="false" data-story-filter="first">
            {{ section.settings.first_label | escape }}
          </button>
          <button type="button" aria-pressed="false" data-story-filter="raw">
            {{ section.settings.raw_label | escape }}
          </button>
        </div>
      </div>
    </header>

    {% if story_articles != blank and story_articles.size > 0 %}
      <div class="story-salon-blog__grid">
        {% for article in story_articles %}
          {% liquid
            assign article_tags = article.tags | join: ' ' | downcase
            assign category = 'all'
            assign series_label = section.settings.all_label

            if article_tags contains 'raw'
              assign category = 'raw'
              assign series_label = section.settings.raw_label
            elsif article_tags contains 'first'
              assign category = 'first'
              assign series_label = section.settings.first_label
            endif

            assign excerpt_text = article.excerpt_or_content | strip_html | strip_newlines | truncate: 140
          %}

          <a
            class="story-salon-blog__card"
            data-story-card
            data-category="{{ category }}"
            href="{{ article.url }}"
          >
            <div class="story-salon-blog__card-media">
              {% if article.image != blank %}
                {{
                  article.image
                  | image_url: width: 1200
                  | image_tag:
                    widths: '400, 700, 1000, 1200',
                    sizes: '(min-width: 900px) 25vw, 50vw',
                    loading: 'lazy',
                    alt: article.title
                }}
              {% else %}
                <div class="story-salon-blog__placeholder"></div>
              {% endif %}

              <span class="story-salon-blog__series">{{ series_label | escape }}</span>
              {% if article.published_at != blank %}
                <span class="story-salon-blog__date">
                  {{ article.published_at | date: '%d %b %Y' }}
                </span>
              {% endif %}
            </div>

            <div class="story-salon-blog__card-copy">
              <h3>{{ article.title | escape }}</h3>
              <p>{{ excerpt_text }}</p>
              <span>{{ section.settings.explore_label | escape }} <span aria-hidden="true">→</span></span>
            </div>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% javascript %}
  document.querySelectorAll('[data-story-salon-blog]').forEach((section) => {
    const buttons = section.querySelectorAll('[data-story-filter]');
    const cards = section.querySelectorAll('[data-story-card]');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.storyFilter;

        buttons.forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
        cards.forEach((card) => {
          card.hidden = filter !== 'all' && card.dataset.category !== filter;
        });
      });
    });
  });
{% endjavascript %}

{% stylesheet %}
  .story-salon-blog {
    background: var(--story-paper, #f5f4f1);
    color: var(--story-ink, #0f1623);
  }

  .story-salon-blog__hero {
    background: var(--story-ink, #0f1623);
    color: #ffffff;
  }

  .story-salon-blog__bar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: clamp(0.9rem, 2vw, 1.2rem) var(--page-margin);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
  }

  .story-salon-blog__mosaic {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    min-height: clamp(24rem, 52vw, 50rem);
    overflow: hidden;
  }

  .story-salon-blog__tile {
    min-width: 0;
    overflow: hidden;
    position: relative;
  }

  .story-salon-blog__tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.28) contrast(1.18) brightness(1.04) drop-shadow(0 18px 40px rgb(0 0 0 / 0.12));
    transition: transform 700ms cubic-bezier(.2, .7, .2, 1);
  }

  .story-salon-blog__tile::after,
  .story-salon-blog__card-media::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .story-salon-blog__tile::after {
    background:
      radial-gradient(circle at 50% 30%, rgb(255 255 255 / 0.18), transparent 42%),
      linear-gradient(to bottom, rgb(255 255 255 / 0.05), transparent 30%, rgb(0 0 0 / 0.18));
    mix-blend-mode: screen;
    opacity: 0.85;
  }

  .story-salon-blog__mosaic:hover .story-salon-blog__tile img {
    transform: scale(1.015);
  }

  .story-salon-blog__title {
    position: absolute;
    inset: auto var(--page-margin) clamp(1.5rem, 4vw, 4rem);
    z-index: 2;
    color: #ffffff;
    max-width: min(34rem, 100%);
    pointer-events: none;
  }

  .story-salon-blog__title p {
    margin: 0;
  }

  .story-salon-blog__title > p:first-child {
    margin-bottom: 0.5rem;
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .story-salon-blog__title h1 {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 7vw, 6rem);
    line-height: 0.82;
    letter-spacing: -0.025em;
  }

  .story-salon-blog__lede {
    margin-top: 0.85rem;
    max-width: 32ch;
    font-size: clamp(0.85rem, 1.2vw, 1rem);
    line-height: 1.55;
    color: rgb(255 255 255 / 0.72);
  }

  .story-salon-blog__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.35rem;
    padding: 0.8rem 1.2rem;
    background: #ffffff;
    color: var(--story-ink, #0f1623);
    text-decoration: none;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    pointer-events: auto;
  }

  .story-salon-blog__journal {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .story-salon-blog__intro {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 2rem;
    align-items: end;
    padding: clamp(2.5rem, 6vw, 6rem) var(--page-margin) clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid color-mix(in srgb, currentColor 12%, transparent);
  }

  .story-salon-blog__intro-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 52%, transparent);
  }

  .story-salon-blog__intro-eyebrow::before {
    content: "";
    width: 1.2rem;
    height: 1px;
    background: color-mix(in srgb, currentColor 38%, transparent);
    flex-shrink: 0;
  }

  .story-salon-blog__intro h2 {
    margin: 0;
    max-width: 24ch;
    font-family: var(--font-heading--family);
    font-size: clamp(1.8rem, 3vw, 3.2rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.025em;
  }

  .story-salon-blog__intro-copy {
    display: grid;
    gap: 1.25rem;
    justify-items: start;
  }

  .story-salon-blog__intro-text {
    max-width: 44rem;
    font-size: 0.95rem;
    line-height: 1.75;
    color: color-mix(in srgb, currentColor 72%, transparent);
  }

  .story-salon-blog__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .story-salon-blog__filters button {
    padding: 0.65rem 1rem;
    border: 1px solid color-mix(in srgb, currentColor 20%, transparent);
    border-radius: 999px;
    color: inherit;
    background: transparent;
    font: inherit;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  .story-salon-blog__filters button[aria-pressed='true'] {
    color: var(--story-paper, #f5f4f1);
    background: var(--story-ink, #0f1623);
    border-color: var(--story-ink, #0f1623);
  }

  .story-salon-blog__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .story-salon-blog__card {
    display: flex;
    min-width: 0;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    border-inline-end: 1px solid currentColor;
  }

  .story-salon-blog__card:nth-child(4n) {
    border-inline-end: 0;
  }

  .story-salon-blog__card[hidden] {
    display: none;
  }

  .story-salon-blog__card-media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #dfe1e3;
  }

  .story-salon-blog__card-media::after {
    background:
      linear-gradient(to top, rgb(15 11 8 / 0.58), transparent 58%),
      radial-gradient(circle at 50% 24%, rgb(255 255 255 / 0.14), transparent 38%);
    mix-blend-mode: screen;
    opacity: 0.9;
  }

  .story-salon-blog__card-media img,
  .story-salon-blog__placeholder {
    width: 100%;
    height: 100%;
  }

  .story-salon-blog__placeholder {
    background:
      repeating-linear-gradient(135deg, rgba(26, 22, 19, 0.045) 0 2px, transparent 2px 11px),
      linear-gradient(160deg, #ded3bd, #c2b69b);
  }

  .story-salon-blog__card-media img {
    object-fit: cover;
    filter: saturate(1.22) contrast(1.12) brightness(1.03);
    transition: transform 500ms ease;
  }

  .story-salon-blog__card:hover img {
    transform: scale(1.025);
  }

  .story-salon-blog__series,
  .story-salon-blog__date {
    position: absolute;
    z-index: 1;
    left: 1rem;
    color: #ffffff;
  }

  .story-salon-blog__series {
    top: 1rem;
    font-size: 0.58rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .story-salon-blog__date {
    top: 1rem;
    right: 1rem;
    left: auto;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.76;
  }

  .story-salon-blog__card-copy {
    padding: 1rem 1rem 1.75rem;
  }

  .story-salon-blog__card-copy h3 {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .story-salon-blog__card-copy p {
    min-height: 4.5em;
    margin: 0.5rem 0 0;
    font-size: 0.78rem;
    line-height: 1.5;
    color: color-mix(in srgb, currentColor 70%, transparent);
  }

  .story-salon-blog__card-copy > span {
    display: inline-block;
    margin-top: 0.8rem;
    color: var(--story-accent, #923531);
    font-size: 0.65rem;
    text-transform: uppercase;
  }

  @media screen and (max-width: 899px) {
    .story-salon-blog__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .story-salon-blog__card:nth-child(4n) {
      border-inline-end: 1px solid currentColor;
    }

    .story-salon-blog__card:nth-child(2n) {
      border-inline-end: 0;
    }
  }

  @media screen and (max-width: 749px) {
    .story-salon-blog__bar {
      font-size: 0.58rem;
      letter-spacing: 0.16em;
    }

    .story-salon-blog__mosaic {
      grid-template-columns: repeat(2, 1fr);
      min-height: 34rem;
    }

    .story-salon-blog__tile:last-of-type {
      display: none;
    }

    .story-salon-blog__title {
      inset-inline: 1rem;
    }

    .story-salon-blog__title h1 {
      font-size: clamp(2rem, 15vw, 4.5rem);
    }

    .story-salon-blog__intro {
      display: grid;
      padding-inline: 1rem;
    }

    .story-salon-blog__grid {
      grid-template-columns: 1fr;
    }

    .story-salon-blog__card {
      border-inline-end: 0;
      border-bottom: 1px solid currentColor;
    }

    .story-salon-blog__card:last-child {
      border-bottom: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Story Salon Blog",
  "enabled_on": {
    "templates": [
      "blog"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Hero eyebrow",
      "default": "The TRIIIPLE Journal"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "Story Salon"
    },
    {
      "type": "textarea",
      "id": "hero_lede",
      "label": "Hero lede",
      "default": "Conversations and portraits from the studio, starting from the first layer up."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Hero CTA label",
      "default": "Read the archive"
    },
    {
      "type": "textarea",
      "id": "intro_heading",
      "label": "Introduction heading",
      "default": "not a campaign. not a lookbook.\na room where people sit down and say something true."
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Introduction text"
    },
    {
      "type": "text",
      "id": "all_label",
      "label": "All filter",
      "default": "All"
    },
    {
      "type": "text",
      "id": "first_label",
      "label": "First Layer filter",
      "default": "The 1st Layer"
    },
    {
      "type": "text",
      "id": "raw_label",
      "label": "Raw filter",
      "default": "Raw n Uncut"
    },
    {
      "type": "text",
      "id": "explore_label",
      "label": "Card link label",
      "default": "Explore"
    },
    {
      "type": "color",
      "id": "paper",
      "label": "Paper",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "ink",
      "label": "Ink",
      "default": "#0f1623"
    },
    {
      "type": "color",
      "id": "accent",
      "label": "Accent",
      "default": "#923531"
    }
  ],
  "presets": [
    {
      "name": "Story Salon Blog"
    }
  ]
}
{% endschema %}
