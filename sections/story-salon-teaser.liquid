<!-- /sections/story-salon-teaser.liquid -->
<!-- Pre-footer: Story Salon blog link + full-width product strip -->

<style>
  .sst {
    background: #f6f1e8;
    color: #17191c;
    border-top: 1px solid rgba(23,25,28,0.08);
  }
  .sst__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 28px clamp(16px, 4vw, 40px) 18px;
  }
  .sst__label {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(23,25,28,0.58);
    margin: 0;
  }
  .sst__shop-all {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #17191c;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: opacity 0.2s;
  }
  .sst__shop-all:hover { opacity: 0.55; }
  .sst__shop-all::after { content: '→'; }
  .sst__tagline {
    padding: 0 clamp(16px, 4vw, 40px) 24px;
    font-family: 'Galdeano', serif;
    font-size: clamp(22px, 2.8vw, 38px);
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: #17191c;
    max-width: 14ch;
    margin: 0;
  }
  .sst__grid-wrap {
    border-top: 1px solid rgba(23,25,28,0.08);
    border-bottom: 1px solid rgba(23,25,28,0.08);
  }
  .sst__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .sst__product-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    background: rgba(255,255,255,0.52);
    border-right: 1px solid rgba(23,25,28,0.08);
  }
  .sst__product-link:last-child { border-right: none; }
  .sst__product-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: rgba(255,255,255,0.38);
    flex-shrink: 0;
  }
  .sst__product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s ease;
  }
  .sst__product-link:hover .sst__product-image img { transform: scale(1.04); }
  .sst__product-info {
    padding: 14px clamp(16px, 4vw, 24px) 0;
    flex: 1;
  }
  .sst__product-title {
    font-family: 'Galdeano', serif;
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: #17191c;
    margin: 0 0 4px;
  }
  .sst__product-price {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(23,25,28,0.58);
    margin: 0 0 16px;
  }
  .sst__product-btn {
    display: block;
    padding: 13px clamp(16px, 4vw, 24px);
    background: transparent;
    border: none;
    border-top: 1px solid rgba(23,25,28,0.08);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #17191c;
    text-align: left;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    width: 100%;
  }
  .sst__product-btn:hover {
    background: var(--COLOR-TEXT, #111);
    color: var(--COLOR-BG, #fff);
  }
  .sst__cta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 28px clamp(16px, 4vw, 40px) 36px;
  }
  .sst__cta {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #17191c;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s;
  }
  .sst__cta:hover { opacity: 0.55; }
  @media screen and (max-width: 749px) {
    .sst__header { padding: 24px 16px 14px; }
    .sst__tagline { padding: 0 16px 20px; max-width: 18ch; }
    .sst__grid { grid-template-columns: 1fr; }
    .sst__product-link { border-right: none; border-top: 1px solid rgba(23,25,28,0.08); }
    .sst__product-link:first-child { border-top: none; }
    .sst__product-info { padding: 12px 16px 0; }
    .sst__product-title { font-size: 18px; }
    .sst__product-price { font-size: 9px; margin-bottom: 10px; }
    .sst__product-btn { font-size: 9px; padding: 10px 16px; }
    .sst__cta-row { padding: 22px 16px 30px; }
  }
</style>

{%- liquid
  assign p1 = all_products[section.settings.product_1]
  assign p2 = all_products[section.settings.product_2]
  assign p3 = all_products[section.settings.product_3]
-%}

<div class="sst">
  <div class="sst__header">
    {%- if section.settings.label != blank -%}
      <p class="sst__label">{{ section.settings.label }}</p>
    {%- endif -%}
    {%- if section.settings.shop_all_url != blank -%}
      <a href="{{ section.settings.shop_all_url }}" class="sst__shop-all">Shop all</a>
    {%- endif -%}
  </div>
  {%- if section.settings.tagline != blank -%}
    <p class="sst__tagline">{{ section.settings.tagline }}</p>
  {%- endif -%}
  {%- if section.settings.show_strip -%}
  <div class="sst__grid-wrap">
    <div class="sst__grid">
      {%- for i in (1..3) -%}
        {%- liquid
          case i
            when 1
              assign product = p1
            when 2
              assign product = p2
            when 3
              assign product = p3
          endcase
        -%}
        {%- if product != blank -%}
          <a href="{{ product.url }}" class="sst__product-link">
            <div class="sst__product-image">
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '33vw' }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag }}
              {%- endif -%}
            </div>
            <div class="sst__product-info">
              <p class="sst__product-title">{{ product.title }}</p>
              <p class="sst__product-price">From {{ product.price_min | money }}</p>
            </div>
            <span class="sst__product-btn">Shop Product</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}
  {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
    <div class="sst__cta-row">
      <a href="{{ section.settings.cta_url }}" class="sst__cta">{{ section.settings.cta_label }}</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Story Salon Blog",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Worn in the stories" },
    { "type": "text", "id": "tagline", "label": "Tagline (optional)" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Read the stories" },
    { "type": "url", "id": "cta_url", "label": "CTA URL (link to blog)" },
    { "type": "header", "content": "Product strip" },
    { "type": "checkbox", "id": "show_strip", "label": "Show product strip", "default": true },
    { "type": "product", "id": "product_1", "label": "Product 1" },
    { "type": "product", "id": "product_2", "label": "Product 2" },
    { "type": "product", "id": "product_3", "label": "Product 3" },
    { "type": "url", "id": "shop_all_url", "label": "Shop all link" }
  ],
  "presets": [{ "name": "Story Salon Blog" }]
}
{% endschema %}
