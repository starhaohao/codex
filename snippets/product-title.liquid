{%- liquid
  assign onboarding_product = onboarding_product | default: false
  assign product_display_name = product.title | strip_html
  assign product_subheading = blank

  if onboarding_product == false and product != blank
    assign product_content = product.metafields.custom.product_content.value

    if product_content != blank
      assign meta_display_name = product_content.display_name.value | strip_html | strip
      if meta_display_name != blank
        assign product_display_name = meta_display_name
      endif

      assign meta_fabric_profile = product_content.fabric_profile.value | strip_html | strip
      assign meta_signature_quote = product_content.signature_quote.value | strip_html | strip

      if meta_fabric_profile != blank
        assign product_subheading = meta_fabric_profile
      elsif meta_signature_quote != blank
        assign product_subheading = meta_signature_quote
      endif
    endif
  endif
-%}

{{ 'breadcrumbs.css' | asset_url | stylesheet_tag }}

<div
  class="product__block product__head block-padding"
  {{ block_style }}
  {% if animation_name %}
    data-animation="{{ animation_name }}"
    data-animation-duration="{{ animation_duration }}"
    data-animation-delay="{{ animation_delay }}"
  {% endif %}
>
  {%- case block.settings.subheading_option -%}
    {%- when 'vendor' -%}
      {%- if product.vendor -%}
        <nav class="breadcrumbs breadcrumbs--no-padding product__breadcrumbs">
          <a href="{{ product.vendor | url_for_vendor }}">{{ product.vendor }}</a>
        </nav>
      {%- endif -%}
    {%- when 'collection' -%}
      {%- if collection or product.collections.size > 0 -%}
        {%- assign current_collection = collection | default: product.collections[0] -%}

        <nav class="breadcrumbs breadcrumbs--no-padding product__breadcrumbs">
          <a href="{{ current_collection.url }}">{{ current_collection.title }}</a>
        </nav>
      {%- endif -%}
    {%- when 'breadcrumb' -%}
      {% render 'breadcrumbs', breadcrumbs_modifier: 'breadcrumbs--no-padding product__breadcrumbs' %}
  {%- endcase -%}

  <div class="product__title__wrapper{% if product_subheading != blank %} product__title__wrapper--with-subtitle{% endif %}" {{ block.shopify_attributes }}>
    <h1 class="product__title {{ block.settings.heading_font_size | default: 'heading-small' }}">
      {%- if onboarding_product -%}
        <span data-zoom-caption>{{ 'home_page.onboarding.product_title' | t }}</span>
      {%- else -%}
        {%- unless is_title_linked -%}
          <span data-zoom-caption>{{ product_display_name | escape }}</span>
        {%- else -%}
          <a href="{{ product.url }}">
            <span data-zoom-caption>{{ product_display_name | escape }}</span>
          </a>
        {%- endunless -%}
      {%- endif -%}
    </h1>

    {%- if product_subheading != blank -%}
      <p class="product__subheading">{{ product_subheading | escape }}</p>
    {%- endif -%}
  </div>
</div>
