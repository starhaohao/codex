{% comment %} Brand deck fonts live in the theme assets so the storefront can use the exact deck typography. {% endcomment %}
<style>
  /* IBM Plex Sans is the single site family; use the available weights consistently. */
  @font-face {
    font-family: 'IBM Plex Sans';
    src: url('{{ 'IBMPlexSans-Regular.ttf' | asset_url }}') format('truetype');
    font-style: normal;
    font-weight: 300;
    font-display: swap;
  }
  @font-face {
    font-family: 'IBM Plex Sans';
    src: url('{{ 'IBMPlexSans-Regular.ttf' | asset_url }}') format('truetype');
    font-style: normal;
    font-weight: 400;
    font-display: swap;
  }

  @font-face {
    font-family: 'IBM Plex Sans';
    src: url('{{ 'IBMPlexSans-Medium.ttf' | asset_url }}') format('truetype');
    font-style: normal;
    font-weight: 500;
    font-display: swap;
  }

  @font-face {
    font-family: 'IBM Plex Sans';
    src: url('{{ 'IBMPlexSans-SemiBold.ttf' | asset_url }}') format('truetype');
    font-style: normal;
    font-weight: 600;
    font-display: swap;
  }

  @font-face {
    font-family: 'IBM Plex Sans';
    src: url('{{ 'IBMPlexSans-Bold.ttf' | asset_url }}') format('truetype');
    font-style: normal;
    font-weight: 700;
    font-display: swap;
  }
</style>
