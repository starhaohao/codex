{% doc %}
Renders product details directly below the product header and reviews.
{% enddoc %}

<div class="product-details-top" {{ block.shopify_attributes }}>
  {% if block.settings.eyebrow != blank %}<p class="product-details-top__eyebrow">{{ block.settings.eyebrow | escape }}</p>{% endif %}
  {% if block.settings.heading != blank %}<h2>{{ block.settings.heading | escape }}</h2>{% endif %}
  <details {% if block.settings.open_by_default %}open{% endif %}>
    <summary><span>{{ block.settings.description_label | escape }}</span><span aria-hidden="true">+</span></summary>
    <div class="product-details-top__body rte">
      {% if closest.product.description != blank %}
        {{ closest.product.description }}
      {% else %}
        {{ block.settings.fallback_description }}
      {% endif %}
    </div>
  </details>
</div>

{% stylesheet %}
  .product-details-top { width: 100%; padding-block: 0.5rem 0.25rem; }
  .product-details-top__eyebrow { margin: 0 0 0.6rem; font-size: 0.66rem; letter-spacing: 0.17em; text-transform: uppercase; }
  .product-details-top > h2 { margin: 0 0 1.5rem; max-width: 15ch; font-family: var(--font-heading--family); font-size: clamp(1.05rem, 1.8vw, 1.4rem); font-weight: 400; line-height: 1.08; }
  .product-details-top details { border-block: 1px solid currentColor; }
  .product-details-top summary { display: flex; justify-content: space-between; gap: 1rem; padding: 1rem 0; cursor: pointer; list-style: none; font-size: 1rem; }
  .product-details-top summary::-webkit-details-marker { display: none; }
  .product-details-top summary span:last-child { transition: transform 180ms ease; }
  .product-details-top details[open] summary span:last-child { transform: rotate(45deg); }
  .product-details-top__body { padding: 0.4rem 0 1.25rem; color: color-mix(in srgb, currentColor 68%, transparent); font-size: 0.88rem; line-height: 1.55; }
  .product-details-top__body > :first-child { margin-top: 0; }
  .product-details-top__body > :last-child { margin-bottom: 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "Product details top",
  "tag": null,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Product details" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Made for the way you move." },
    { "type": "text", "id": "description_label", "label": "Description label", "default": "Description" },
    { "type": "richtext", "id": "fallback_description", "label": "Fallback description", "default": "<p>Add the product description in Shopify admin.</p>" },
    { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": true }
  ],
  "presets": [{ "name": "Product details top", "category": "Product" }]
}
{% endschema %}
